@model OnwardsSwift.Core.DTOs.ChequeEncashmentViewModel
@{
    ViewData["Title"] = "Cheque Encashment — Step 2";
    var isEmbeddedInWizard = (ViewData["EmbedInWizard"] as bool?) == true;
}

@if (!isEmbeddedInWizard)
{
    <div class="container py-3">
        <div class="card shadow-sm border-0 mb-3 text-center py-3">
            <img src="@Url.Content("~/images/onwards-logo.jpg")" alt="Onwards Swift" class="mx-auto d-block" style="height:54px;width:auto;object-fit:contain;" />
            <div class="mt-2">
                <h2 class="h5 mb-1">Cheque Encashment - Step 2</h2>
                <p class="text-muted mb-0 small">Enter cheque details and complete the terms acknowledgement before continuing.</p>
            </div>
        </div>
    </div>

    @:<div class="card p-3">
    @:<h2>Cheque Encashment — Step 2</h2>
}
<!-- Modal wrapper for step 2 -->
<div class="modal fade" id="chequeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-fullscreen-sm-down">
        <div class="modal-content">
            <div class="modal-header border-0">
                <div class="d-flex align-items-center w-100">
                    <div class="me-3">
                        <svg width="48" height="48" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <rect width="100" height="100" rx="14" fill="#002D72" />
                            <text x="50" y="58" font-family="Segoe UI,Arial" font-size="40" fill="#fff" text-anchor="middle">O</text>
                        </svg>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="modal-title mb-0">Cheque Encashment</h5>
                        <small class="text-muted">Step 2: Enter cheque details and attach documents</small>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal" aria-label="Close"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
            <div class="modal-body">
                <form asp-action="ChequeEncashment" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ClientId" />

                    <div class="mb-3 p-2 bg-primary text-white rounded">
                        <strong>CHEQUE ENCASHMENT APPLICATION FORM</strong>
                        <span class="float-end small">Please complete all fields and attach cheque copy</span>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <h6 class="mb-2">Applicant / Payee</h6>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Name</label>
                            <input asp-for="ApplicantName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Postal Address</label>
                            <input asp-for="PostalAddress" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Phone</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-12 mt-2">
                            <input class="form-control form-control-sm" placeholder="Search client by name or ID" />
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-4">
                            <label class="form-label">Account No.</label>
                            <input name="AccountNumber" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ID / Passport No.</label>
                            <input asp-for="IdNumber" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bank</label>
                            <input name="Bank" class="form-control" />
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Category</label>
                            <select asp-for="Category" id="ceCategory" class="form-select">
                                <option value="Individual">Individual</option>
                                <option value="Company">Company</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Payment Method</label>
                            <input type="text" id="cePaymentMethodDisplay" class="form-control" disabled value="M-Pesa" />
                            <small class="text-muted">Determined automatically by Category</small>
                        </div>
                    </div>
                    <div class="row mt-3" id="ceBankPaymentSection" style="display:none;">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Bank Name</label>
                            <input asp-for="DisburseBank" id="ceDisburseBank" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Bank Account Number</label>
                            <input asp-for="DisburseAccount" id="ceDisburseAccount" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <h6>Cheque(s) Details</h6>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40px">No.</th>
                                        <th>Cheque Number</th>
                                        <th style="width:130px">Amount in KES (in Figures)</th>
                                        <th style="width:140px">Dated (dd/mm/yy)</th>
                                        <th>Drawer</th>
                                        <th>Bank</th>
                                        <th>Branch</th>
                                        <th>Payee</th>
                                        <th style="width:90px"></th>
                                    </tr>
                                </thead>
                                <tbody id="chequeTableBody">
                                    @for(int i=1;i<=4;i++){
                                        <tr>
                                            <td>@i</td>
                                            <td><input name="Cheques[@(i-1)].Number" class="form-control form-control-sm" placeholder="Cheque #" /></td>
                                            <td><input name="Cheques[@(i-1)].Amount" class="form-control form-control-sm text-end" placeholder="0.00" /></td>
                                            <td><input type="text" name="Cheques[@(i-1)].Dated" class="form-control form-control-sm" placeholder="dd/mm/yyyy" /></td>
                                            <td><input name="Cheques[@(i-1)].Drawer" class="form-control form-control-sm" /></td>
                                            <td><input name="Cheques[@(i-1)].Bank" class="form-control form-control-sm" /></td>
                                            <td><input name="Cheques[@(i-1)].Branch" class="form-control form-control-sm" /></td>
                                            <td><input name="Cheques[@(i-1)].Payee" class="form-control form-control-sm" /></td>
                                            <td><button type="button" class="btn btn-sm btn-danger remove-row">Remove</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="d-flex justify-content-end mb-3">
                            <button type="button" id="addRow" class="btn btn-sm btn-primary">Add row</button>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <label class="form-label fw-bold">Purpose</label>
                            <textarea asp-for="Purpose" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Attachments</label>
                            <input type="file" id="Attachments" name="Attachments" accept="application/pdf,image/*" multiple class="form-control" />
                            <small class="text-muted">Please attach scanned cheque and required KYC documents — PDF / JPG / PNG. Max 10MB each.</small>
                            <div id="attachmentList" class="mt-2"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Documents required (Cheque Discounting)</label>
                            <div class="border rounded p-2" style="background:#f8f9fa">
                                <ol class="mb-0 small">
                                    <li>Individual cheques from a reputable institution
                                        <ul>
                                            <li>Original copy of the cheque (must be current; no post-dated cheques)</li>
                                            <li>Original identity card of the payee</li>
                                            <li>KRA PIN of the director</li>
                                            <li>Supporting document validating the payment</li>
                                        </ul>
                                    </li>
                                    <li class="mt-2">Company cheques from a reputable institution
                                        <ul>
                                            <li>Company KRA PIN certificate</li>
                                            <li>Certificate of registration / incorporation</li>
                                            <li>Directors PIN certificate</li>
                                            <li>Original Directors' identity card</li>
                                            <li>CR-12</li>
                                            <li>Board resolution on company letterhead signed by all directors agreeing on discounting the cheques and the mandate on each transaction</li>
                                        </ul>
                                    </li>
                                </ol>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="card p-2">
                                <strong>Charges</strong>
                                <p class="mb-0 small">Charges: 5% on the cheque amount<br/>Minimum charges: Ksh. 300</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card p-2 border-danger">
                                <strong>Bounced cheque</strong>
                                <p class="mb-0 small">Charges – Ksh. 5,000<br/>Replacement of the cheque should be immediate</p>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <h6>Declaration &amp; Signature</h6>
                            <p class="small text-muted">I/We confirm the information provided is true. I/We authorise Onwards Swift to encash the cheque on my behalf.</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Name</label>
                            <input name="DeclarantName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Role</label>
                            <input name="DeclarantRole" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Date</label>
                            <input type="date" name="DeclarantDate" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-3 border rounded p-3" style="background:#f8fbff">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                            <div>
                                <strong class="d-block">Terms and Conditions</strong>
                                <small class="text-muted">Read and accept terms before proceeding to Official Use or submitting this request.</small>
                                <div class="mt-1">
                                    <a href="@Url.Action("TermsAndConditions", "Forms")" target="_blank" rel="noopener" class="small">Open Terms and Conditions</a>
                                </div>
                            </div>
                            <a href="#" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#termsConditionsModal">Read Terms and Conditions</a>
                        </div>

                        <div class="form-check mt-3 mb-1">
                            <input asp-for="TermsAccepted" class="form-check-input" />
                            <label class="form-check-label" asp-for="TermsAccepted">I confirm that I have read and accepted the Terms and Conditions.</label>
                        </div>
                        <span asp-validation-for="TermsAccepted" class="text-danger small"></span>
                    </div>

                    <div class="mt-4 d-flex gap-2 justify-content-end">
                        <button type="button" id="openOfficialUseBtn" class="btn btn-secondary">Save &amp; Continue to Official Use</button>
                        <button type="submit" class="btn btn-primary" id="submitChequeBtn">Submit</button>
                        <button type="reset" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (!isEmbeddedInWizard)
{
    @await Html.PartialAsync("~/Views/Forms/OfficialUse.cshtml", new OnwardsSwift.Core.DTOs.OfficialUseViewModel { RequestId = Model?.ClientId ?? 0 })
}

    <script>
        (function(){
            console.debug('ChequeEncashment script loaded');
            // Ensure Official Use modal is a direct child of <body> to avoid nested-modal/backdrop issues
            try{
                const ou = document.getElementById('officialUseModal');
                if(ou && ou.parentElement !== document.body){
                    document.body.appendChild(ou);
                    console.debug('Moved officialUseModal to document.body');
                }
            }catch(e){ console.debug('move officialUseModal failed', e); }
            const tbody = document.getElementById('chequeTableBody');
            const addRowBtn = document.getElementById('addRow');
            const termsAcceptedCheckbox = document.getElementById('TermsAccepted');
            const submitChequeBtn = document.getElementById('submitChequeBtn');

            // Category -> Payment Method (Individual = M-Pesa, Company = Bank)
            const ceCategorySelect = document.getElementById('ceCategory');
            const cePaymentMethodDisplay = document.getElementById('cePaymentMethodDisplay');
            const ceBankPaymentSection = document.getElementById('ceBankPaymentSection');
            const ceDisburseBank = document.getElementById('ceDisburseBank');
            const ceDisburseAccount = document.getElementById('ceDisburseAccount');

            function syncCePaymentMethod() {
                const isCompany = ceCategorySelect?.value === 'Company';
                if (cePaymentMethodDisplay) cePaymentMethodDisplay.value = isCompany ? 'Bank Transfer' : 'M-Pesa';
                if (ceBankPaymentSection) ceBankPaymentSection.style.display = isCompany ? '' : 'none';
                if (ceDisburseBank) ceDisburseBank.required = isCompany;
                if (ceDisburseAccount) ceDisburseAccount.required = isCompany;
            }

            if (ceCategorySelect) {
                ceCategorySelect.addEventListener('change', syncCePaymentMethod);
                syncCePaymentMethod();
            }
            if(tbody && addRowBtn){
                addRowBtn.addEventListener('click', ()=>{
                    const next = tbody.rows.length + 1;
                    const tr = document.createElement('tr');
                    tr.innerHTML = `<td>${next}</td><td><input class="form-control form-control-sm cheque-number" /></td><td><input class="form-control form-control-sm amount-fig" /></td><td><input type="date" class="form-control form-control-sm dated" /></td><td><input class="form-control form-control-sm drawer" /></td><td><input class="form-control form-control-sm bank" /></td><td><input class="form-control form-control-sm branch" /></td><td><input class="form-control form-control-sm payee" /></td><td><button type="button" class="btn btn-sm btn-danger remove-row">Remove</button></td>`;
                    tbody.appendChild(tr);
                });
                tbody.addEventListener('click', (e)=>{
                    if(e.target && e.target.classList.contains('remove-row')){
                        const row = e.target.closest('tr'); row.remove();
                        Array.from(tbody.rows).forEach((r,i)=> r.cells[0].textContent = (i+1).toString());
                    }
                });
            }

            function syncTermsGate(){
                const accepted = !!termsAcceptedCheckbox?.checked;
                if(openOfficialUseBtn) openOfficialUseBtn.disabled = !accepted;
                if(submitChequeBtn) submitChequeBtn.disabled = !accepted;
            }

            if(termsAcceptedCheckbox){
                termsAcceptedCheckbox.addEventListener('change', syncTermsGate);
            }

            // Attachments file list UI — accumulates across multiple picks
            const attachmentsInput = document.querySelector('input[name="Attachments"]');
            const attachmentList = document.getElementById('attachmentList');

            // Master list kept in a DataTransfer so we can accumulate across picks
            let attachmentsDT = new DataTransfer();

            function renderAttachmentList(){
                if(!attachmentList) return;
                attachmentList.innerHTML = '';
                if(attachmentsDT.files.length === 0) return;
                const ul = document.createElement('ul');
                ul.className = 'list-group';
                Array.from(attachmentsDT.files).forEach((f, i) => {
                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex justify-content-between align-items-center py-1';
                    const nameSpan = document.createElement('span');
                    nameSpan.className = 'small';
                    nameSpan.textContent = f.name + ' (' + Math.round(f.size / 1024) + ' KB)';
                    const rm = document.createElement('button');
                    rm.type = 'button';
                    rm.className = 'btn btn-sm btn-outline-danger ms-2';
                    rm.innerHTML = '<i class="bi bi-x"></i>';
                    rm.title = 'Remove';
                    rm.addEventListener('click', () => {
                        const newDT = new DataTransfer();
                        Array.from(attachmentsDT.files).forEach((file, idx) => {
                            if (idx !== i) newDT.items.add(file);
                        });
                        attachmentsDT = newDT;
                        attachmentsInput.files = attachmentsDT.files;
                        renderAttachmentList();
                    });
                    li.appendChild(nameSpan);
                    li.appendChild(rm);
                    ul.appendChild(li);
                });
                attachmentList.appendChild(ul);
            }

            if (attachmentsInput) {
                attachmentsInput.addEventListener('change', () => {
                    // Merge newly picked files; skip duplicates (same name + size)
                    Array.from(attachmentsInput.files).forEach(newFile => {
                        const isDuplicate = Array.from(attachmentsDT.files).some(
                            existing => existing.name === newFile.name && existing.size === newFile.size
                        );
                        if (!isDuplicate) attachmentsDT.items.add(newFile);
                    });
                    // Push merged list back into the input so the form POST carries all files
                    attachmentsInput.files = attachmentsDT.files;
                    renderAttachmentList();
                });
            }

            // Advance to Step 3 by submitting the saved cheque request first.
            const openOfficialUseBtn = document.getElementById('openOfficialUseBtn');
            if(openOfficialUseBtn){
                openOfficialUseBtn.addEventListener('click', ()=>{
                    if(termsAcceptedCheckbox && !termsAcceptedCheckbox.checked){
                        alert('Please read and accept the Terms and Conditions before continuing.');
                        return;
                    }
                    const form = openOfficialUseBtn.closest('form');
                    if (form) {
                        form.requestSubmit(submitChequeBtn || undefined);
                    }
                });
            }

            syncTermsGate();
        })();
    </script>

<script>
    // Note: modal is opened by the onboarding wizard. Do not auto-show here.
</script>

@if (!isEmbeddedInWizard)
{
    @:</div>
}


<!-- Terms & Conditions Modal (Step 2) -->
<div class="modal fade" id="termsConditionsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Cheque Encashment Terms and Conditions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body small">
                <p>For collection by themselves and hereby agree and undertake that:</p>
                <ol>
                    <li>I confirm and undertake that if the cheque(s) above is/are not honored for whatever reason I shall upon demand of not less than seven (7) days from the date of such demand repay the cash collected plus interest at 5% for every 2 weeks and any other charges incurred in respect to the cheque(s) not being honored to Onwards Swift Company Limited.</li>
                    <li>I agree and undertake that if the cheque(s) mentioned is/are not honored for whatever reason, I hereby give a personal guarantee and pledge my personal and or family household assets namely: refrigerator, television set, radio and other electronics, microwave, dining table and chairs, gas cooker, beds and/or any other additional assets as may be sufficient to repay the cash advanced to me such as motor vehicles and I hereby waive any claims of ownership of the said assets by any third party whatsoever, PROVIDED THAT any attachment of my assets a seven (7) days' notice shall be given before sale is made by private treaty and/or public auction whichever Onwards Swift Company Limited may deem fit.</li>
                    <li>Any request and demand made upon ONWARDS SWIFT COMPANY LIMITED by any person(s) legally entitled to the cheque(s) shall be sufficient authority to ONWARDS SWIFT COMPANY LIMITED to make good such proceeds through recovery from myself.</li>
                    <li>I indemnify ONWARDS SWIFT COMPANY LIMITED from and against all action, proceeding, damages, costs, claims, demands or losses which you may suffer, incur or sustain or are made to you by reason or on your account having agreed that the cheque(s) be endorsed to you or otherwise in the premises however.</li>
                    <li>Cheque(s) represent genuine trade transactions and I shall be fully responsible for any discrepancies in the cheque(s).</li>
                    <li>THAT in the event of bankruptcy liquidation, analogous proceedings, or any other reason, or the inability of myself, or the drawer, at any time to any the cheque(s) as and of when it falls due (such occurrence to be decided by ONWARDS SWIFT COMPANY LIMITED at its discretion), I will become liable to pay you the face value of the cheque(s) together with all charges and penalties as per clause (i) above.</li>
                    <li>In case the amount of the cheque(s) is/are attached or held by a court of law for any reason, I shall repay you all due sums on first demand.</li>
                    <li>I have read and fully understood the terms and conditions of this letter of indemnity without any coercion whatsoever and undertake to abide strictly by the said terms and conditions.</li>
                    <li>I acknowledge and consent that the information provided, pursuant to this transaction, shall be handled, processed, stored in accordance with ONWARDS SWIFT Data Privacy statement available in our website www.onwardsswift.co.ke from time to time.</li>
                </ol>
                <h6 class="mb-1">ACCEPTANCE</h6>
                <p class="mb-0">I, ________________________________, of I.D Number __________________________, being an adult of sound mind and legal capacity, do hereby appoint Onwards Swift Limited to act as debt collection agent in case of default by the drawer. I also hereby confirm acceptance of the above indemnity having read and had a chance to seek independent advise thereof and fully understood the terms and conditions thereof.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
