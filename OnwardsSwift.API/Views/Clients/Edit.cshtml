@model OnwardsSwift.Core.DTOs.CreateClientRequest
@{ ViewData["Title"] = "Edit Client"; }

<div class="page-header">
    <h1>Edit Client</h1>
    <div class="subtitle">@ViewBag.ClientName</div>
</div>

<div class="content-body">
<form asp-action="Edit" asp-route-id="@ViewBag.ClientId" method="post">
    @Html.AntiForgeryToken()
    <div class="row"><div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header">Company Information</div>
            <div class="card-body row g-3">
                <div class="col-md-8">
                    <label class="form-label">Company Name</label>
                    <input asp-for="CompanyName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Client Type</label>
                    <select asp-for="ClientType" class="form-select"
                        asp-items="Html.GetEnumSelectList<OnwardsSwift.Core.Enums.ClientType>()"></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">KRA PIN</label>
                    <input asp-for="KraPin" class="form-control" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Business Reg. No.</label>
                    <input asp-for="BusinessRegNumber" class="form-control" />
                </div>
            </div>
        </div>
        <div class="card mb-3">
            <div class="card-header">Contact Details</div>
            <div class="card-body row g-3">
                <div class="col-md-6">
                    <label class="form-label">Contact Person</label>
                    <input asp-for="ContactPerson" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Alt Phone</label>
                    <input asp-for="PhoneAlt" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Physical Address</label>
                    <input asp-for="PhysicalAddress" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Postal Address</label>
                    <input asp-for="PostalAddress" class="form-control" />
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-navy px-4">Save Changes</button>
            <a asp-action="Details" asp-route-id="@ViewBag.ClientId" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div></div>
</form>
</div>
