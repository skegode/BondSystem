@model OnwardsSwift.Core.DTOs.CreateClientRequest
@{ ViewData["Title"] = "New Client"; }

<div class="page-header">
    <h1>New Client</h1>
    <div class="subtitle">Register a new client on the platform</div>
</div>

<div class="content-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header">Company Information</div>
                <div class="card-body row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Company Name <span class="text-danger">*</span></label>
                        <input asp-for="CompanyName" class="form-control" />
                        <span asp-validation-for="CompanyName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Client Type</label>
                        <select asp-for="ClientType" class="form-select"
                            asp-items="Html.GetEnumSelectList<OnwardsSwift.Core.Enums.ClientType>()"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">KRA PIN <span class="text-danger">*</span></label>
                        <input asp-for="KraPin" class="form-control" placeholder="A000000000X" />
                        <span asp-validation-for="KraPin" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Business Reg. No.</label>
                        <input asp-for="BusinessRegNumber" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Credit Limit (KSh)</label>
                        <input asp-for="CreditLimit" class="form-control" placeholder="0.00" data-amount="true" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Contact Details</div>
                <div class="card-body row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Contact Person <span class="text-danger">*</span></label>
                        <input asp-for="ContactPerson" class="form-control" />
                        <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone <span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" placeholder="+254700000000" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Alt Phone</label>
                        <input asp-for="PhoneAlt" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Address</div>
                <div class="card-body row g-3">
                    <div class="col-12">
                        <label class="form-label">Physical Address <span class="text-danger">*</span></label>
                        <input asp-for="PhysicalAddress" class="form-control" />
                        <span asp-validation-for="PhysicalAddress" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Postal Address</label>
                        <input asp-for="PostalAddress" class="form-control" placeholder="P.O. Box 0000-00100 Nairobi" />
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-navy px-4">
                    <i class="bi bi-person-plus me-1"></i>Create Client
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>
</div>
