@model OnwardsSwift.Core.DTOs.ForgotPasswordRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Forgot Password — Onwards Swift</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .card { max-width: 480px; margin: 6rem auto; }
        .btn-navy { background:#002D72; color:#fff; }
    </style>
</head>
<body>
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h4 class="mb-3">Reset your password</h4>
            <p class="text-muted small">Enter the email associated with your account. We'll send instructions to reset your password.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger small">
                    <ul class="mb-0">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small text-uppercase">Email address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@company.com" required />
                </div>
                <button class="btn btn-navy w-100 py-2" type="submit">Send reset instructions</button>
                <a asp-action="Login" class="d-block text-center mt-3 small text-decoration-none">Back to sign in</a>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
