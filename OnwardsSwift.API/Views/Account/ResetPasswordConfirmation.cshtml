@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Password Updated - Onwards Swift</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .card { max-width: 640px; margin: 6rem auto; }
        .btn-navy { background:#002D72; color:#fff; }
    </style>
</head>
<body>
    <div class="card shadow-sm">
        <div class="card-body p-4 text-center">
            <h4 class="mb-2">Password reset successful</h4>
            <p class="text-muted">Your password has been updated. You can now sign in with your new password.</p>
            <a asp-action="Login" class="btn btn-navy mt-3">Sign in</a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
