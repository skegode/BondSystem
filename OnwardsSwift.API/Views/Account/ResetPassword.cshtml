@model OnwardsSwift.Core.DTOs.ResetPasswordViaTokenRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Set New Password - Onwards Swift</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .card { max-width: 520px; margin: 5rem auto; }
        .btn-navy { background:#002D72; color:#fff; }
    </style>
</head>
<body>
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h4 class="mb-3">Set a new password</h4>
            <p class="text-muted small">Create a new password for your account.</p>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Email" type="hidden" />
                <input asp-for="ResetToken" type="hidden" />

                <div class="mb-3">
                    <label class="form-label small text-uppercase">Email</label>
                    <input asp-for="Email" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label small text-uppercase">New password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" minlength="8" required />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-uppercase">Confirm password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" minlength="8" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button class="btn btn-navy w-100 py-2" type="submit">Update password</button>
                <a asp-action="Login" class="d-block text-center mt-3 small text-decoration-none">Back to sign in</a>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
