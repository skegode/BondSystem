@model OnwardsSwift.Core.DTOs.LoginRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign In — Onwards Swift</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --navy: #002D72;
            --light-bg: #f8f9fa;
        }

        body {
            background-color: var(--light-bg);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .split-container {
            min-height: 100vh;
            display: flex;
        }

        /* Left Side: Branding/Marketing */
        .brand-side {
            background: linear-gradient(135deg, var(--navy) 0%, #001f4d 100%);
            color: white;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
        }

        /* Right Side: Login Form */
        .form-side {
            background: white;
            width: 450px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
            box-shadow: -10px 0 30px rgba(0,0,0,0.05);
        }

        .btn-navy {
            background-color: var(--navy);
            color: white;
            border: none;
            font-weight: 600;
        }

            .btn-navy:hover {
                background-color: #001f4d;
                color: white;
            }

        .form-control {
            padding: 0.75rem 1rem;
            border-color: #e0e0e0;
        }

            .form-control:focus {
                border-color: var(--navy);
                box-shadow: none;
            }

        .login-logo {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -1px;
        }

        .brand-logo-img {
            max-width: 320px;
            width: 100%;
            height: auto;
            object-fit: contain;
            filter: drop-shadow(0 8px 18px rgba(0, 0, 0, 0.22));
        }

        .brand-onboarding-card {
            max-width: 560px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 14px;
            padding: 1.5rem;
            backdrop-filter: blur(2px);
        }

        .brand-onboarding-title {
            font-size: 1.45rem;
            font-weight: 700;
            margin-bottom: 0.6rem;
        }

        .brand-onboarding-list {
            list-style: none;
            padding-left: 0;
            margin-bottom: 1.25rem;
        }

        .brand-onboarding-list li {
            display: flex;
            align-items: flex-start;
            gap: 0.55rem;
            margin-bottom: 0.7rem;
            opacity: 0.95;
        }

        .brand-onboarding-list i {
            color: #4cd7ff;
            margin-top: 0.1rem;
        }

        .btn-onboarding-link {
            background: #fff;
            color: var(--navy);
            border: 0;
            font-weight: 700;
            padding: 0.62rem 1rem;
        }

        .btn-onboarding-link:hover {
            background: #e8f1ff;
            color: #001f4d;
        }

        .form-logo-img {
            max-width: 210px;
            width: 100%;
            height: auto;
            object-fit: contain;
        }

        @@media (max-width: 992px) {
            .brand-side {
                display: none;
            }

            .form-side {
                width: 100%;
                padding: 2rem;
            }
        }
    </style>
</head>
<body>

    <div class="split-container">
        <div class="brand-side">
            <div class="brand-onboarding-card">
                <h2 class="brand-onboarding-title">Client Onboarding Wizard</h2>
                <p class="opacity-75 mb-3">
                    This portal offers two guided workflows: the <a href="@Url.Action("OnboardingWizard", "Forms")" class="text-white text-decoration-underline">Client Onboarding Wizard</a>
                    — used to register clients, capture KYC and cheque-encashment details, and complete internal approvals; and the
                    <a href="@Url.Action("FullApplication", "Forms")" class="text-white text-decoration-underline">Bank Guarantee / Bond Request Wizard</a>
                    — used to submit bond applications, attach supporting documents, and confirm counter-guarantee/indemnity terms.
                </p>

                <div class="d-flex gap-2">
                    <a class="btn btn-onboarding-link" href="@Url.Action("Landing", "Forms")">Open Onboarding Portal <i class="bi bi-arrow-right ms-1"></i></a>
                    <a class="btn btn-outline-light" href="@Url.Action("FullApplication", "Forms")">Open Bond Request Wizard</a>
                </div>
            </div>
        </div>

        <div class="form-side">
            <div class="mb-5">
                <img src="@Url.Content("~/images/onwards-logo.jpg")" alt="Onwards Swift" class="form-logo-img mb-2" />
                <p class="text-muted">Welcome back. Please sign in to your account.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger border-0 small shadow-sm mb-4">
                    <ul class="mb-0">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="name@company.com" autocomplete="username" required />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label class="form-label fw-semibold small text-uppercase">Password</label>
                        <a asp-action="ForgotPassword" class="small text-decoration-none">Forgot?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••••" autocomplete="current-password" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-navy w-100 py-3 mb-4 shadow-sm">
                    Sign In to Platform <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            <div class="mt-auto text-center">
                <p class="small text-muted mb-0">&copy; @DateTime.Now.Year Onwards Swift. All rights reserved.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>