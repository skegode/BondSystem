@model OnwardsSwift.Core.DTOs.LoginRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign In — Onwards Swift</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --navy: #002D72;
            --light-bg: #f8f9fa;
        }

        body {
            background-color: var(--light-bg);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .split-container {
            min-height: 100vh;
            display: flex;
        }

        /* Left Side: Branding/Marketing */
        .brand-side {
            background: linear-gradient(135deg, var(--navy) 0%, #001f4d 100%);
            color: white;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
        }

        /* Right Side: Login Form */
        .form-side {
            background: white;
            width: 450px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
            box-shadow: -10px 0 30px rgba(0,0,0,0.05);
        }

        .btn-navy {
            background-color: var(--navy);
            color: white;
            border: none;
            font-weight: 600;
        }

            .btn-navy:hover {
                background-color: #001f4d;
                color: white;
            }

        .form-control {
            padding: 0.75rem 1rem;
            border-color: #e0e0e0;
        }

            .form-control:focus {
                border-color: var(--navy);
                box-shadow: none;
            }

        .login-logo {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -1px;
        }

        @@media (max-width: 992px) {
            .brand-side {
                display: none;
            }

            .form-side {
                width: 100%;
                padding: 2rem;
            }
        }
    </style>
</head>
<body>

    <div class="split-container">
        <div class="brand-side">
            <div class="mb-4">
                <i class="bi bi-shield-check" style="font-size: 3rem;"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3">Onwards Swift</h1>
            <p class="lead opacity-75 mb-5">Enterprise Trade Finance & Bond Management System.</p>

            <div class="mt-4">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-check-circle-fill me-3 text-info"></i>
                    <span>Automated Bond Issuance & Tracking</span>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-check-circle-fill me-3 text-info"></i>
                    <span>Real-time Portfolio Performance Analytics</span>
                </div>
                <div class="d-flex align-items-center">
                    <i class="bi bi-check-circle-fill me-3 text-info"></i>
                    <span>Secure Multi-Stage Approval Workflows</span>
                </div>
            </div>
        </div>

        <div class="form-side">
            <div class="mb-5">
                <div class="login-logo mb-1">Onwards Swift</div>
                <p class="text-muted">Welcome back. Please sign in to your account.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger border-0 small shadow-sm mb-4">
                    <ul class="mb-0">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="name@company.com" autocomplete="username" required />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label class="form-label fw-semibold small text-uppercase">Password</label>
                        <a asp-action="ForgotPassword" class="small text-decoration-none">Forgot?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••••" autocomplete="current-password" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-navy w-100 py-3 mb-4 shadow-sm">
                    Sign In to Platform <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            <div class="mt-auto text-center">
                <p class="small text-muted mb-0">&copy; @DateTime.Now.Year Onwards Swift. All rights reserved.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>