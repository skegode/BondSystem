@model OnwardsSwift.Core.DTOs.BondClaimRequest
@{ ViewData["Title"] = "Record Bond Claim"; }

<div class="page-header">
    <h1>Record Bond Claim</h1>
    <div class="subtitle">This will mark the bond as Called and record the claim details</div>
</div>

<div class="content-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row"><div class="col-lg-7">
        <div class="alert alert-warning small">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Recording a claim will set the bond status to <strong>Called (Rejected)</strong>. This cannot be undone.
        </div>

        <div class="card mb-3">
            <div class="card-header">Claim Details</div>
            <div class="card-body row g-3">
                <div class="col-12">
                    <label class="form-label">Bond Facility <span class="text-danger">*</span></label>
                    <select asp-for="FacilityId" class="form-select" asp-items="ViewBag.Facilities">
                        <option value="">-- Select Bond --</option>
                    </select>
                    <span asp-validation-for="FacilityId" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Obligee (Claimant) <span class="text-danger">*</span></label>
                    <input asp-for="Obligee" class="form-control" placeholder="Name of procuring entity making the claim" />
                    <span asp-validation-for="Obligee" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Defaulting Bid (KSh)</label>
                    <input asp-for="DefaultingBid" class="form-control" data-amount="true" placeholder="Our client's bid" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Next Lowest Bid (KSh)</label>
                    <input asp-for="NextLowestBid" class="form-control" data-amount="true" placeholder="Second-lowest bidder" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Claim Amount (KSh)</label>
                    <input asp-for="ClaimAmount" class="form-control" data-amount="true" placeholder="Leave 0 to auto-calculate" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Claim Date</label>
                    <input asp-for="ClaimDate" class="form-control" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Claim Reference</label>
                    <input asp-for="ClaimReference" class="form-control" placeholder="Obligee reference number" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4"
                data-confirm="Record this bond claim? The facility will be marked as Called.">
                <i class="bi bi-exclamation-triangle me-1"></i>Record Bond Claim
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div></div>
</form>
</div>
