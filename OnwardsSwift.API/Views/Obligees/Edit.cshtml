@{ ViewData["Title"] = "Edit Obligee"; }

<div class="page-header"><h1>Edit Obligee</h1></div>

<div class="content-body">
<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <div class="row"><div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header">Obligee Details</div>
            <div class="card-body row g-3">
                <div class="col-md-8">
                    <label class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input name="name" value="@Model.Name" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Short Name</label>
                    <input name="shortName" value="@Model.ShortName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        @foreach (var cat in new[]{"Government","County","Parastatal","Private","NGO"})
                        {
                            @if (cat == (string?)Model.Category)
                            { <option value="@cat" selected>@cat</option> }
                            else
                            { <option value="@cat">@cat</option> }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contact Person</label>
                    <input name="contactPerson" value="@Model.ContactPerson" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input name="email" value="@Model.Email" class="form-control" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phone</label>
                    <input name="phone" value="@Model.Phone" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Address</label>
                    <input name="address" value="@Model.Address" class="form-control" />
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-navy px-4">Save Changes</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div></div>
</form>
</div>
