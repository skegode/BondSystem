@{ ViewData["Title"] = "Add Obligee"; }

<div class="page-header"><h1>Add Obligee</h1></div>

<div class="content-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row"><div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header">Obligee Details</div>
            <div class="card-body row g-3">
                <div class="col-md-8">
                    <label class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input name="name" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Short Name</label>
                    <input name="shortName" class="form-control" placeholder="e.g. KeRRA" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="Government">Government</option>
                        <option value="County">County Government</option>
                        <option value="Parastatal">Parastatal</option>
                        <option value="Private">Private</option>
                        <option value="NGO">NGO / Development</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contact Person</label>
                    <input name="contactPerson" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input name="email" class="form-control" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phone</label>
                    <input name="phone" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Address</label>
                    <input name="address" class="form-control" />
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-navy px-4">Save Obligee</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div></div>
</form>
</div>
