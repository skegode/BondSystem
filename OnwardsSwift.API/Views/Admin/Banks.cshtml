@using System.Collections.Generic
@model List<dynamic>
@{
    ViewData["Title"] = "Bank Partners";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Bank Partners</h1>
        <div class="text-muted small">Issuing banks and insurance companies</div>
    </div>
    <a asp-action="CreateBank" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i>Add Partner
    </a>
</div>

<div class="content-body">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Type</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var b in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    @b.BankName
                                </td>
                                <td>
                                    @{
                                        // Handle potential null or dynamic cast for BankType
                                        var itype = b.InstitutionType != null ? (int)b.InstitutionType : 1;
                                    }
                                    @if (itype == 2)
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2">
                                            <i class="bi bi-shield-check me-1"></i>Insurance
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-2">
                                            <i class="bi bi-bank me-1"></i>Bank
                                        </span>
                                    }
                                </td>
                                <td class="small text-muted">@(b.ContactEmail ?? "—")</td>
                                <td class="small text-muted">@(b.ContactPhone ?? "—")</td>
                                <td class="text-center">
                                    @if (b.IsActive==1)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="EditBank" asp-route-id="@b.Id" class="btn btn-sm btn-white border">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                                No bank partners recorded yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>