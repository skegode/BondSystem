@model List<OnwardsSwift.Core.DTOs.NavMenu>
@{
    ViewData["Title"] = "Menu Management";
    // Grouping logic to help visualize the hierarchy in the table
    var mainMenus = Model.Where(m => m.ParentId == null).OrderBy(m => m.SortOrder).ToList();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">System Navigation Manager</h3>
            <p class="text-muted">Configure the dynamic sidebar and access permissions.</p>
        </div>
        <a asp-action="CreateMenu" class="btn btn-primary px-4 py-2 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Create New Menu
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4" style="width: 30%;">Menu Label</th>
                            <th style="width: 25%;">Route / URL</th>
                            <th class="text-center" style="width: 10%;">Sort</th>
                            <th class="text-center" style="width: 15%;">Visibility</th>
                            <th class="text-center" style="width: 10%;">Access</th>
                            <th class="text-end pe-4" style="width: 10%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var parent in mainMenus)
                        {
                            <tr class="table-white border-bottom-2">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-3">
                                            <i class="bi @(parent.Icon ?? "bi-folder") fs-5"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark">@parent.Title</span>
                                            <div class="small text-muted">ID: #@parent.Id (Main)</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <code>/@parent.Controller/@parent.Action</code>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">@parent.SortOrder</span>
                                </td>
                                <td class="text-center">
                                    @if (parent.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3">Hidden</span>
                                    }
                                </td>
                                <td class="text-center text-muted">
                                    <i class="bi @(string.IsNullOrEmpty(parent.AllowedUserIds) ? "bi-globe2 text-success" : "bi-lock-fill text-warning")"
                                       title="@(string.IsNullOrEmpty(parent.AllowedUserIds) ? "Everyone" : "Restricted: " + parent.AllowedUserIds)"></i>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="EditMenu" asp-route-id="@parent.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </a>
                                </td>
                            </tr>

                            var subMenus = Model.Where(m => m.ParentId == parent.Id).OrderBy(m => m.SortOrder).ToList();
                            @foreach (var sub in subMenus)
                            {
                                <tr class="bg-light bg-opacity-25">
                                    <td class="ps-5">
                                        <div class="d-flex align-items-center">
                                            <span class="text-muted me-3">↳</span>
                                            <div class="text-dark">@sub.Title</div>
                                        </div>
                                    </td>
                                    <td class="ps-4 small text-muted">
                                        /@sub.Controller/@sub.Action
                                    </td>
                                    <td class="text-center">
                                        <span class="small text-muted">@sub.SortOrder</span>
                                    </td>
                                    <td class="text-center">
                                        @if (sub.IsActive)
                                        {
                                            <span class="small text-success fw-bold">Active</span>
                                        }
                                        else
                                        {
                                            <span class="small text-danger fw-bold">Hidden</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <i class="bi bi-person-fill-lock small text-muted" title="@sub.AllowedUserIds"></i>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="EditMenu" asp-route-id="@sub.Id" class="btn btn-sm btn-link text-primary p-0">
                                            Edit
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-3 border-0">
            <div class="small text-muted">
                <i class="bi bi-info-circle me-1"></i>
                <strong>Note:</strong> Items hidden (Inactive) will not appear in the sidebar navigation for any user.
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom spacing for the hierarchy look */
    .border-bottom-2 {
        border-bottom: 2px solid #f0f0f0 !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.03) !important;
    }

    code {
        background: #f8f9fa;
        color: #d63384;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.85rem;
    }
</style>