@model List<dynamic>
@{
    ViewData["Title"] = "Product Rates";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">Product Rates</h1>
            <p class="text-secondary mb-0">Manage global commission structures and partner bank interest rates.</p>
        </div>
        <a asp-action="CreateRate" class="btn btn-primary px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>New Rate Configuration
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 fw-bold text-primary"><i class="bi bi-sliders me-2"></i>Active Configurations</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-uppercase small fw-bold text-muted">Product</th>
                        <th class="text-uppercase small fw-bold text-muted">Partner Bank</th>
                        <th class="text-uppercase small fw-bold text-muted">Bank Charges (%)</th>
                        <th class="text-uppercase small fw-bold text-muted">App. Fee</th>
                        <th class="text-uppercase small fw-bold text-muted">Commission</th>
                        <th class="text-uppercase small fw-bold text-muted text-center">Status</th>
                        <th class="pe-4 text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        // 1. Dynamic Product Name from Joined Table
                        var ptName = r.ProductName ?? "Unknown Product";

                        // 2. Commission Type Logic
                        var ct = r.CommissionType == null ? 1 : Convert.ToInt32(r.CommissionType);
                        var ctSuffix = ct switch { 1 => "% of Fee", 2 => " Fixed", 3 => "% of Principal", _ => "%" };

                        // 3. Application Fee Logic (Formatting for small decimals like 0.005)
                        var aft = r.ApplicationFeeType == null ? 2 : Convert.ToInt32(r.ApplicationFeeType);
                        var afValue = (decimal)(r.ApplicationFee ?? 0);
                        var afDisplay = aft == 2 ? $"KES {afValue:N2}" : $"{afValue:G29}%";

                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@ptName</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-bank text-primary me-2"></i>
                                    <span>@r.BankName</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-soft-primary text-primary border px-2">@((decimal)(r.Rate ?? 0) * 100)%</span>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">@afDisplay</span>
                                <div class="text-muted small" style="font-size: 0.75rem;">One-off Fee</div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@((decimal)(r.Commission ?? 0))@ctSuffix</div>
                            </td>
                            <td class="text-center">
                                @if (r.IsActive == 1)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3">Inactive</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light border" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item" asp-action="EditRate" asp-route-id="@r.Id"><i class="bi bi-pencil me-2 text-muted"></i>Edit</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="DeleteRate" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Delete this rate configuration?')">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-database-exclamation display-4 text-light d-block mb-3"></i>
                                <p class="text-muted">No rate configurations found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: rgba(13, 110, 253, 0.08) !important;
        border-color: rgba(13, 110, 253, 0.2) !important;
    }

    .table thead th {
        font-size: 0.75rem;
        background-color: #fcfcfc;
    }
</style>