@model OnwardsSwift.Core.DTOs.NavMenu
@{
    ViewData["Title"] = "Add Menu Item";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-primary">Add New Menu Item</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="CreateMenu" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Menu Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Asset Management" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Bootstrap Icon Class</label>
                    <input asp-for="Icon" class="form-control" placeholder="bi-gear-fill" />
                    <div class="form-text">Example: bi-database, bi-cash-stack</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Parent Menu (Optional)</label>
                    <select asp-for="ParentId" class="form-select select2">
                        <option value="">-- Set as Top Level Menu --</option>
                        @foreach (var parent in ViewBag.Parents)
                        {
                            <option value="@parent.Id">@parent.Title</option>
                        }
                    </select>
                    <div class="form-text">Choose a parent if this is a sub-menu.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Sort Order</label>
                    <input asp-for="SortOrder" type="number" class="form-control" value="0" />
                </div>

                <hr class="my-4" />

                <div class="col-md-4">
                    <label class="form-label fw-bold">Controller</label>
                    <input asp-for="Controller" class="form-control" placeholder="e.g. Finance" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Action</label>
                    <input asp-for="Action" class="form-control" placeholder="e.g. Index" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Allowed User IDs (CSV)</label>
                    <input asp-for="AllowedUserIds" class="form-control" placeholder="1, 5, 12" />
                    <div class="form-text">Leave blank for everyone.</div>
                </div>

                <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-2"></i>Save Menu Item
                    </button>
                    <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>