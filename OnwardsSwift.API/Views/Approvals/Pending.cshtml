@model IEnumerable<OnwardsSwift.Core.DTOs.PendingBondVM>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark"><i class="bi bi-clock-history me-2"></i>Pending Approvals</h3>
        <span class="badge bg-primary rounded-pill">@Model.Count() Applications Waiting</span>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="pendingTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Date Applied</th>
                            <th>Client & Tender</th>
                            <th>Bond Type</th>
                            <th>Amount (KES)</th>
                            <th>Payment</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="small fw-bold">@item.CreatedAt.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted small">@item.CreatedAt.ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    <div class="fw-bold">@item.ClientName</div>
                                    <div class="text-muted small">@item.TenderNumber - @item.TenderName</div>
                                </td>
                                <td><span class="badge bg-light text-dark border">@item.BondTypeName</span></td>
                                <td class="fw-bold">@item.Amount.ToString("N2")</td>
                                <td>
                                    @if (item.IsDeferredPayment)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle me-1"></i>Pay Later</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Paid</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-sm btn-primary px-3 shadow-sm">
                                        Review & Approve
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Optional: Initialize DataTables for searching and sorting
            $('#pendingTable').DataTable({
                "order": [[0, "desc"]],
                "pageLength": 10
            });
        });
    </script>
}