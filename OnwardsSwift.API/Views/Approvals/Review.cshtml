@model OnwardsSwift.Core.DTOs.BondReviewViewModel
@{
    ViewData["Title"] = "Review Bond Application";
    var bond     = Model.Bond;
    var workflow = Model.Workflow;
    bool canAct  = Model.IsCurrentApprover && workflow != null && workflow.IsActive;
    string sessionRole = (Context.Session.GetString("UserRole") ?? string.Empty).Trim();
    bool isAdmin = User.IsInRole("Admin") || string.Equals(sessionRole, "Admin", StringComparison.OrdinalIgnoreCase);
    bool canChangePaymentStatus = isAdmin || canAct;
    bool showDecisionPanel = workflow != null && workflow.IsActive;
    bool approveBlockedByDocs = workflow != null && workflow.HasMissingRequiredDocs;
}

<style>
    :root { --navy: #002D72; }
    .bg-navy    { background-color: var(--navy) !important; }
    .text-navy  { color: var(--navy) !important; }
    .btn-navy   { background-color: var(--navy); color: #fff; }
    .btn-navy:hover { background-color: #001a44; color: #fff; }
    .border-navy { border-color: var(--navy) !important; }
    .section-divider { border: 0; border-top: 1px solid #e2e8f0; margin: 0; }
    .kv-row { display:flex; justify-content:space-between; padding:.5rem 0;
              border-bottom:1px solid #f1f5f9; font-size:.875rem; }
    .kv-row:last-child { border-bottom: none; }
    .kv-key { color:#64748b; font-weight:500; }
    .kv-val { font-weight:600; text-align:right; }
    .amount-hero   { font-size:2rem; font-weight:800; letter-spacing:-.03em; }
    .stage-step.is-past    { color:#16a34a; }
    .stage-step.is-current { color:var(--navy); font-weight:700; }
    .stage-step.is-future  { color:#94a3b8; }
</style>

<div class="container-fluid py-4 px-3 px-lg-4">

    @* ── Breadcrumb & header ── *@
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item">
                            <a asp-action="Pending" class="text-decoration-none">Approvals</a>
                        </li>
                        <li class="breadcrumb-item active">Review Bond</li>
                    </ol>
                </nav>
                <h4 class="fw-bold mb-0">@bond.TenderNumber</h4>
                <div class="text-muted small">@bond.TenderName</div>
            </div>
            <a asp-action="Pending" class="btn btn-sm btn-light border px-3">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-3">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3">

        @* ── LEFT column ── *@
        <div class="col-lg-8">

            @* Project details *@
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2 text-primary"></i>Project Details</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Client</div>
                            <div class="fw-bold">@bond.ClientName</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Procuring Entity</div>
                            <div class="fw-semibold">@bond.ProcuringEntityName</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Agent / Broker</div>
                            <div class="small"><i class="bi bi-person-badge me-1 text-muted"></i>@(bond.AgentName ?? "Direct Application")</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Bond Type</div>
                            <span class="badge px-3 py-1 fw-semibold"
                                  style="background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; border-radius:20px;">
                                @bond.BondTypeName
                            </span>
                        </div>
                        <div class="col-12">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Tender Description</div>
                            <div class="p-3 rounded-3" style="background:#f8fafc; border-left:4px solid #002D72;">
                                @bond.TenderName
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mt-2">
                        <div class="col-3">
                            <div class="text-center p-3 rounded-3 border">
                                <div class="text-muted small mb-1">Bond Amount</div>
                                <div class="fw-bold" style="color:var(--navy);">KES @bond.Amount.ToString("N0")</div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="text-center p-3 rounded-3 border">
                                <div class="text-muted small mb-1">Tenor</div>
                                <div class="fw-bold">@bond.TenorDays days</div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="text-center p-3 rounded-3 border">
                                <div class="text-muted small mb-1">Closing Date</div>
                                <div class="fw-bold text-danger small">@bond.TenderClosingDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="text-center p-3 rounded-3 border">
                                <div class="text-muted small mb-1">Processing Date</div>
                                <div class="fw-bold small">@(bond.ProcessingDate?.ToString("dd MMM yyyy") ?? "—")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Application documents *@
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-files me-2 text-primary"></i>Application Documents</h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (!string.IsNullOrEmpty(bond.TenderDocPath))
                        {
                            <a href="@bond.TenderDocPath" target="_blank"
                               class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-file-earmark-pdf text-danger me-2"></i>Tender Document</span>
                                <span class="btn btn-sm btn-light border">View <i class="bi bi-box-arrow-up-right ms-1"></i></span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(bond.CR12Path))
                        {
                            <a href="@bond.CR12Path" target="_blank"
                               class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-file-earmark-person text-info me-2"></i>CR12 / Legal Compliance</span>
                                <span class="btn btn-sm btn-light border">View <i class="bi bi-box-arrow-up-right ms-1"></i></span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(bond.PaymentReceiptPath))
                        {
                            <a href="@bond.PaymentReceiptPath" target="_blank"
                               class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-receipt text-success me-2"></i>Payment Receipt</span>
                                <span class="btn btn-sm btn-outline-success fw-bold">View <i class="bi bi-check-all ms-1"></i></span>
                            </a>
                        }
                        @if (string.IsNullOrEmpty(bond.TenderDocPath) && string.IsNullOrEmpty(bond.CR12Path) && string.IsNullOrEmpty(bond.PaymentReceiptPath))
                        {
                            <div class="list-group-item text-muted fst-italic py-3 small">No documents uploaded yet.</div>
                        }
                    </div>
                </div>
            </div>

            @* Stage documents checklist *@
            @if (workflow != null && workflow.RequiredDocuments.Any())
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-card-checklist me-2 text-primary"></i>Stage Documents Checklist</h6>
                        @{
                            int doneCount = workflow.RequiredDocuments.Count - workflow.MissingRequiredDocNames.Count;
                        }
                        <span class="badge @(workflow.HasMissingRequiredDocs ? "bg-warning text-dark" : "bg-success") px-3">
                            @doneCount / @workflow.RequiredDocuments.Count complete
                        </span>
                    </div>
                    <ul class="list-group list-group-flush mb-0">
                        @foreach (var doc in workflow.RequiredDocuments)
                        {
                            bool uploaded = workflow.UploadedDocuments
                                .Any(ud => ud.DocumentName.Equals(doc.DocumentName, StringComparison.OrdinalIgnoreCase));
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div class="d-flex align-items-center gap-2">
                                    @if (uploaded)
                                    {
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    }
                                    else if (doc.IsRequired)
                                    {
                                        <i class="bi bi-exclamation-circle-fill text-danger"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-circle text-muted"></i>
                                    }
                                    <span class="@(uploaded ? "text-muted text-decoration-line-through" : "fw-semibold") small">
                                        @doc.DocumentName
                                    </span>
                                    @if (!doc.IsRequired)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary" style="font-size:.65rem;">Optional</span>
                                    }
                                </div>
                                @if (!uploaded)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            onclick="showUploadModal('@doc.DocumentName', @bond.Id)">
                                        <i class="bi bi-upload me-1"></i>Upload
                                    </button>
                                }
                                else
                                {
                                    var uploadedDoc = workflow.UploadedDocuments
                                        .First(ud => ud.DocumentName.Equals(doc.DocumentName, StringComparison.OrdinalIgnoreCase));
                                    <a href="@uploadedDoc.FilePath" target="_blank" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                }
                            </li>
                        }
                    </ul>
                </div>
            }

            @* Approval history *@
            @if (workflow != null && workflow.History.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Approval History</h6>
                    </div>
                    <div class="card-body">
                        @foreach (var h in workflow.History)
                        {
                            @* Determine icon and colour per action type *@
                            string dotBg    = h.ActionType == "APPROVED" ? "#dcfce7" : h.ActionType == "REJECTED" ? "#fee2e2" : "#fef9c3";
                            string dotColor = h.ActionType == "APPROVED" ? "#16a34a" : h.ActionType == "REJECTED" ? "#dc2626" : "#d97706";
                            string dotIcon  = h.ActionType == "APPROVED" ? "bi-check-lg"
                                            : h.ActionType == "REJECTED" ? "bi-x-lg"
                                            : "bi-arrow-return-left";
                            <div class="d-flex gap-3 mb-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:36px;height:36px;background:@dotBg;border:2px solid @dotColor;">
                                    <i class="bi @dotIcon" style="color:@dotColor; font-size:.8rem;"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold small">
                                        @h.ActionLabel
                                        <span class="badge ms-1 px-2 py-1"
                                              style="background:@dotBg;color:@dotColor;border:1px solid @dotColor;font-size:.65rem;border-radius:12px;">
                                            @h.StageName
                                        </span>
                                    </div>
                                    <div class="text-muted small">
                                        by <strong>@h.ActionByName</strong> &mdash; @h.ActionAt.ToString("dd MMM yyyy, hh:mm tt")
                                    </div>
                                    @if (!string.IsNullOrEmpty(h.Comment))
                                    {
                                        <div class="mt-1 small fst-italic text-muted">&ldquo;@h.Comment&rdquo;</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── RIGHT column ── *@
        <div class="col-lg-4">

            @* Pricing summary *@
            <div class="card border-0 shadow-sm mb-3" style="border-top:4px solid var(--navy);">
                <div class="card-body p-4">
                    <div class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing:.08em;">Pricing Summary</div>
                    <div class="text-center py-3">
                        <div class="text-muted small text-uppercase fw-semibold mb-1" style="letter-spacing:.07em;">Bond Amount</div>
                        <div class="amount-hero" style="color:var(--navy);">KES @bond.Amount.ToString("N0")</div>
                    </div>
                    <hr class="my-2" />
                    <div class="kv-row">
                        <span class="kv-key">Client Charge</span>
                        <span class="kv-val">KES @bond.ClientCharge.ToString("N2")</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key">Bank Charge</span>
                        <span class="kv-val">KES @bond.BankCharge.ToString("N2")</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key">Tax Percentage</span>
                        <span class="kv-val">@bond.TaxPercentage.ToString("N2")%</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key">Tax Calculation</span>
                        <span class="kv-val">KES @bond.TaxCalculation.ToString("N2")</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key">Total Bank Charge</span>
                        <span class="kv-val">KES @bond.TotalBankCharge.ToString("N2")</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key text-success">Net Profit</span>
                        <span class="kv-val text-success">KES @bond.NetProfit.ToString("N2")</span>
                    </div>
                    <div class="kv-row" style="border-top:2px solid #e2e8f0; padding-top:.75rem; margin-top:.25rem;">
                        <span class="kv-key fw-bold">Total Charged</span>
                        <span class="kv-val fw-bold" style="color:var(--navy);">KES @bond.ClientCharge.ToString("N2")</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key fw-bold">Total Paid</span>
                        <span class="kv-val fw-bold text-success">KES @bond.PaidAmount.ToString("N2")</span>
                    </div>
                    <div class="kv-row">
                        <span class="kv-key fw-bold">Outstanding</span>
                        <span class="kv-val fw-bold @(bond.OutstandingAmount > 0 ? "text-danger" : "text-success")">KES @bond.OutstandingAmount.ToString("N2")</span>
                    </div>

                    <div class="mt-3 pt-3" style="border-top:1px solid #e2e8f0;">
                        <div class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing:.08em;">Payment Status</div>
                        <div class="mb-2">
                            @if (bond.IsDeferredPayment)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-x-circle me-1"></i>Unpaid</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle"><i class="bi bi-check-circle-fill me-1"></i>Paid</span>
                            }
                        </div>

                        <div class="kv-row">
                            <span class="kv-key">Total Charged</span>
                            <span class="kv-val">KES @bond.ClientCharge.ToString("N2")</span>
                        </div>
                        <div class="kv-row">
                            <span class="kv-key">Total Paid</span>
                            <span class="kv-val text-success">KES @bond.PaidAmount.ToString("N2")</span>
                        </div>
                        <div class="kv-row mb-2">
                            <span class="kv-key">Outstanding</span>
                            <span class="kv-val @(bond.OutstandingAmount > 0 ? "text-danger" : "text-success")">
                                KES @bond.OutstandingAmount.ToString("N2")
                            </span>
                        </div>

                        <div class="small text-muted mb-2">
                            <div><strong>Reference:</strong> @(string.IsNullOrWhiteSpace(bond.PaymentReference) ? "—" : bond.PaymentReference)</div>
                            <div><strong>Method:</strong> @(string.IsNullOrWhiteSpace(bond.PaymentMethod) ? "—" : bond.PaymentMethod)</div>
                        </div>

                        <form asp-action="SavePaymentDetails" method="post" class="d-grid gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bondId" value="@bond.Id" />

                            <div class="input-group input-group-sm">
                                <label class="input-group-text" for="paymentStatusSelect">Set Status</label>
                                <select id="paymentStatusSelect" name="isPaid" class="form-select" @(canChangePaymentStatus ? "" : "disabled")>
                                    @if (!bond.IsDeferredPayment)
                                    {
                                        <option value="true" selected>Paid</option>
                                        <option value="false">Unpaid</option>
                                    }
                                    else
                                    {
                                        <option value="true">Paid</option>
                                        <option value="false" selected>Unpaid</option>
                                    }
                                </select>
                            </div>

                            <input type="number"
                                name="amountPaid"
                                class="form-control form-control-sm"
                                step="0.01"
                                min="0.01"
                                max="@bond.OutstandingAmount"
                                placeholder="Amount paid (optional)"
                                @(canChangePaymentStatus && bond.OutstandingAmount > 0 ? "" : "disabled") />

                            <input type="text"
                                name="paymentReference"
                                class="form-control form-control-sm"
                                value="@bond.PaymentReference"
                                placeholder="Payment reference"
                                maxlength="100"
                                @(canChangePaymentStatus ? "" : "disabled") />

                            <select name="paymentMethod" class="form-select form-select-sm" @(canChangePaymentStatus ? "" : "disabled")>
                                @if (string.Equals(bond.PaymentMethod, "MPESA", StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="">Select payment method</option>
                                    <option value="MPESA" selected>Mpesa</option>
                                    <option value="BANK">Bank</option>
                                    <option value="CHEQUE">Cheque</option>
                                }
                                else if (string.Equals(bond.PaymentMethod, "BANK", StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="">Select payment method</option>
                                    <option value="MPESA">Mpesa</option>
                                    <option value="BANK" selected>Bank</option>
                                    <option value="CHEQUE">Cheque</option>
                                }
                                else if (string.Equals(bond.PaymentMethod, "CHEQUE", StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="">Select payment method</option>
                                    <option value="MPESA">Mpesa</option>
                                    <option value="BANK">Bank</option>
                                    <option value="CHEQUE" selected>Cheque</option>
                                }
                                else
                                {
                                    <option value="" selected>Select payment method</option>
                                    <option value="MPESA">Mpesa</option>
                                    <option value="BANK">Bank</option>
                                    <option value="CHEQUE">Cheque</option>
                                }
                            </select>

                            <textarea name="notes"
                                      class="form-control form-control-sm"
                                      rows="2"
                                      maxlength="300"
                                      placeholder="Notes (optional)"
                                      @(canChangePaymentStatus ? "" : "disabled")></textarea>

                            <button type="submit" class="btn btn-outline-primary btn-sm" @(canChangePaymentStatus ? "" : "disabled")>
                                Save Payment Details
                            </button>
                        </form>

                        @{
                            var paymentHistory = ViewBag.PaymentHistory as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                        }
                        @if (paymentHistory.Any())
                        {
                            <div class="mt-3">
                                <div class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing:.08em;">Recent Payments</div>
                                <div class="list-group list-group-flush border rounded">
                                    @foreach (var p in paymentHistory)
                                    {
                                        <div class="list-group-item small">
                                            <div class="d-flex justify-content-between">
                                                <strong class="text-success">KES @(((decimal)p.AmountPaid).ToString("N2"))</strong>
                                                <span class="text-muted">@(((DateTime)p.PaymentDate).ToString("dd MMM yyyy HH:mm"))</span>
                                            </div>
                                            <div>
                                                <span class="text-muted">Method:</span> @(p.PaymentMethod ?? "—")
                                                <span class="text-muted ms-2">Ref:</span> @(p.PaymentReference ?? "—")
                                            </div>
                                            @if (p.Notes != null && !string.IsNullOrWhiteSpace((string)p.Notes))
                                            {
                                                <div class="text-muted fst-italic">@p.Notes</div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        @if (!canChangePaymentStatus)
                        {
                            <div class="small text-muted mt-2">Only Admin or the current stage approver can change payment status.</div>
                        }
                    </div>
                </div>
            </div>

            @* Cash cover *@
            @if (bond.HasCashCover && bond.CashCoverAmount > 0)
            {
                <div class="card border-0 shadow-sm mb-3" style="border-left:4px solid #0ea5e9 !important;">
                    <div class="card-body">
                        <div class="small text-uppercase fw-bold text-muted mb-2">Cash Cover Secured</div>
                        <div class="fw-bold fs-5 text-primary mb-2">KES @bond.CashCoverAmount?.ToString("N0")</div>
                        <div class="kv-row">
                            <span class="kv-key">Maturity</span>
                            <span class="kv-val">@(bond.CashCoverMaturityDate?.ToString("dd MMM yyyy") ?? "—")</span>
                        </div>
                        <div class="kv-row">
                            <span class="kv-key">Reference</span>
                            <span class="kv-val">@(bond.CashCoverReceiptRef ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(bond.CashCoverReceiptPath))
                        {
                            <a href="@bond.CashCoverReceiptPath" target="_blank"
                               class="btn btn-sm btn-outline-primary w-100 mt-2">
                                <i class="bi bi-file-earmark-medical me-1"></i>View Bank Slip
                            </a>
                        }
                    </div>
                </div>
            }

            @* Workflow progress *@
            @if (workflow != null)
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2"></i>Workflow Progress</h6>
                    </div>
                    <ul class="list-group list-group-flush mb-0">
                        @foreach (var stage in Model.AllStages.OrderBy(s => s.SequenceOrder))
                        {
                            bool isCurrent = stage.Id == workflow.CurrentStageId;
                            bool isPast    = stage.SequenceOrder < workflow.CurrentSequenceOrder
                                             || (!workflow.IsActive && !workflow.IsRejected);
                            string stepClass = isPast    ? "is-past"
                                             : isCurrent ? "is-current"
                                             : "is-future";
                            string stepIcon  = isPast    ? "bi-check-circle-fill text-success"
                                             : isCurrent ? "bi-arrow-right-circle-fill"
                                             : "bi-circle text-muted";
                            <li class="list-group-item d-flex align-items-center gap-2 py-2 stage-step @stepClass">
                                <i class="bi @stepIcon @(isCurrent ? "text-navy" : "")"></i>
                                <span class="small">@stage.SequenceOrder. @stage.StageName</span>
                                @if (isCurrent && workflow.IsActive)
                                {
                                    <span class="badge ms-auto px-2 py-1 text-white"
                                          style="background:var(--navy);font-size:.6rem;border-radius:10px;">NOW</span>
                                }
                            </li>
                        }
                    </ul>
                    @if (workflow.IsComplete)
                    {
                        <div class="card-footer bg-success-subtle text-success text-center fw-semibold py-2 small">
                            <i class="bi bi-check-circle-fill me-1"></i>Workflow Complete — Approved
                        </div>
                    }
                    else if (workflow.IsRejected)
                    {
                        <div class="card-footer bg-danger-subtle text-danger text-center fw-semibold py-2 small">
                            <i class="bi bi-x-circle-fill me-1"></i>Application Rejected
                        </div>
                    }
                </div>
            }

            @* Current approvers *@
            @if (workflow != null && workflow.IsActive && workflow.CurrentStageApprovers.Any())
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body py-3">
                        <div class="small fw-bold text-uppercase text-muted mb-2">Awaiting Action From</div>
                        @foreach (var approver in workflow.CurrentStageApprovers)
                        {
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-person-circle text-navy fs-5"></i>
                                <span class="small fw-bold">@approver.FullName</span>
                                <span class="badge bg-light text-muted border ms-auto" style="font-size:.65rem;">@approver.Role</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @* Missing docs warning *@
            @if (workflow != null && workflow.IsActive && workflow.HasMissingRequiredDocs)
            {
                <div class="alert alert-warning border-0 shadow-sm mb-3">
                    <div class="fw-bold small"><i class="bi bi-exclamation-triangle-fill me-2"></i>Missing Documents</div>
                    <ul class="mb-0 small mt-1 ps-3">
                        @foreach (var d in workflow.MissingRequiredDocNames)
                        {
                            <li>@d</li>
                        }
                    </ul>
                    <div class="small mt-2 text-muted">Upload these before approving.</div>
                </div>
            }

            @* Action panel *@
            @if (showDecisionPanel)
            {
                <div class="card border-0 shadow-sm" style="border-top:4px solid var(--navy) !important;">
                    <div class="card-header bg-white py-3">
                        <div class="fw-bold">Your Decision</div>
                        <div class="small text-muted">Stage: <strong>@workflow!.CurrentStageName</strong></div>
                    </div>
                    <div class="card-body">
                        <form asp-action="Act" method="post" id="actionForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="InstanceId" value="@workflow!.Id" />
                            <input type="hidden" name="BondId"     value="@bond.Id" />
                            <input type="hidden" name="ActionType" id="ActionType" value="" />

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    Remarks <span class="text-muted fw-normal">(required for return / reject)</span>
                                </label>
                                <textarea name="Comment" id="Comment" class="form-control" rows="3"
                                          placeholder="Add notes or reason..."></textarea>
                            </div>

                            @if (!canAct)
                            {
                                <div class="alert alert-light border small py-2">
                                    <i class="bi bi-lock me-1"></i>
                                    You can view this stage, but only the assigned current approver can submit an approve/reject action.
                                </div>
                            }

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-success fw-bold py-2"
                                        @(!canAct || approveBlockedByDocs ? "disabled title=\"Upload all required stage documents before approving.\"" : "")
                                        onclick="submitAction('APPROVED')">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    @(workflow.IsFinalStage ? "Final Approve" : "Approve")
                                </button>

                                @if (workflow.CanReturn)
                                {
                                    <button type="button" class="btn btn-warning fw-bold py-2"
                                            @(!canAct ? "disabled" : "")
                                            onclick="submitAction('RETURNED')">
                                        <i class="bi bi-arrow-return-left me-2"></i>Return for Revision
                                    </button>
                                }

                                <button type="button" class="btn btn-outline-danger py-2"
                                        @(!canAct ? "disabled" : "")
                                        onclick="submitAction('REJECTED')">
                                    <i class="bi bi-x-circle me-2"></i>Reject Application
                                </button>
                            </div>

                            @if (approveBlockedByDocs)
                            {
                                <div class="alert alert-warning mt-3 mb-0 py-2 small">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                    Approval is currently blocked because required stage documents are missing.
                                </div>
                            }
                        </form>
                    </div>
                </div>
            }
            else if (workflow == null)
            {
                <div class="alert alert-secondary border-0 shadow-sm">
                    <i class="bi bi-info-circle me-2"></i>No workflow has been configured for this application.
                </div>
            }

        </div>
    </div>
</div>

@* ── Upload document modal ── *@
<div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form asp-action="UploadDocument" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="bondId"       value="@bond.Id" />
                <input type="hidden" name="documentName" id="uploadDocName" value="" />
                <div class="modal-header bg-navy text-white">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Upload Document</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="fw-semibold mb-3" id="uploadDocLabel"></p>
                    <input type="file" name="file" class="form-control" required
                           accept=".pdf,.jpg,.jpeg,.png,.docx" />
                    <div class="form-text mt-1">Accepted: PDF, JPG, PNG, DOCX</div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-navy px-4">
                        <i class="bi bi-upload me-1"></i>Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function submitAction(actionType) {
    const actionForm = document.getElementById('actionForm');
    if (!actionForm) return;

    const disabledButton = actionType === 'APPROVED'
        ? actionForm.querySelector("button[onclick=\"submitAction('APPROVED')\"]")
        : actionType === 'RETURNED'
            ? actionForm.querySelector("button[onclick=\"submitAction('RETURNED')\"]")
            : actionForm.querySelector("button[onclick=\"submitAction('REJECTED')\"]");

    if (disabledButton && disabledButton.disabled) {
        return;
    }

    const comment = document.getElementById('Comment').value.trim();
    if ((actionType === 'REJECTED' || actionType === 'RETURNED') && comment.length < 3) {
        alert('Please provide a reason before ' +
              (actionType === 'REJECTED' ? 'rejecting' : 'returning') + ' this application.');
        return;
    }
    document.getElementById('ActionType').value = actionType;
    document.getElementById('actionForm').submit();
}

function showUploadModal(docName, bondId) {
    document.getElementById('uploadDocName').value  = docName;
    document.getElementById('uploadDocLabel').textContent = docName;
    new bootstrap.Modal(document.getElementById('uploadModal')).show();
}
</script>
}
