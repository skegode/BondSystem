@model List<OnwardsSwift.Core.DTOs.CashCoverViewModel>
@{
    ViewData["Title"] = "Cash Covers";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 fw-bold text-navy mb-1">Cash Covers</h1>
        <div class="text-muted small">Manage and monitor active cash cover accounts</div>
    </div>
    <a asp-action="Create" class="btn btn-navy shadow-sm">
        <i class="bi bi-plus-circle me-1"></i>Record Cash Cover
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light extra-small text-uppercase text-muted">
                <tr>
                    <th class="ps-4">Bond Ref</th>
                    <th>Client / Tender</th>
                    <th class="text-end">Cash Cover</th>
                    <th class="text-center">Maturity</th>
                    <th class="text-center">Days Left</th>
                    <th>Bank</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-4"><code class="fw-bold">@r.BondRef</code></td>
                            <td>
                                <div class="fw-bold small">@r.ClientName</div>
                                <div class="extra-small text-muted text-truncate" style="max-width: 200px;">@r.TenderName</div>
                            </td>
                            <td class="text-end fw-bold text-navy">@r.CashCoverAmount.ToString("N2")</td>
                            <td class="text-center small">@(r.MaturityDate?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td class="text-center">
                                @if (r.MaturityDate.HasValue)
                                {
                                    <span class="badge @(r.DaysRemaining < 15 ? "bg-danger" : r.DaysRemaining < 45 ? "bg-warning text-dark" : "bg-light text-dark")">
                                        @r.DaysRemaining d
                                    </span>
                                }
                            </td>
                            <td class="small">@r.HoldingBank</td>
                            <td>
                                @if (r.Status == "Pending Release")
                                {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle">
                                        <i class="bi bi-clock-history me-1"></i> Awaiting Auth
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">@r.Status</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (r.Status == "Active")
                                {
                                    <button class="btn btn-sm btn-outline-warning fw-bold py-1"
                                            data-bs-toggle="modal" data-bs-target="#releaseModal-@r.Id">
                                        Release
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-light disabled py-1">Locked</button>
                                }
                            </td>
                        </tr>
                        @await Html.PartialAsync("_ReleaseModal", r)
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted italic">No cash covers found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>