@model OnwardsSwift.Core.DTOs.CashCoverRequest
@{ ViewData["Title"] = "Record Cash Cover"; }

<div class="page-header"><h1>Record Cash Cover</h1>
    <div class="subtitle">Associate a cash deposit with an existing bond facility</div>
</div>

<div class="content-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row"><div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header">Cash Cover Details</div>
            <div class="card-body row g-3">
                <div class="col-12">
                    <label class="form-label">Bond Facility <span class="text-danger">*</span></label>
                    <select asp-for="FacilityId" class="form-select" asp-items="ViewBag.Facilities">
                        <option value="">-- Select Bond --</option>
                    </select>
                    <span asp-validation-for="FacilityId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cash Cover Amount (KSh) <span class="text-danger">*</span></label>
                    <input asp-for="CashCoverAmount" class="form-control" data-amount="true" placeholder="0.00" />
                    <span asp-validation-for="CashCoverAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cover % of Bond</label>
                    <input asp-for="CashCoverPct" class="form-control" type="number" step="0.1" min="0" max="100" placeholder="e.g. 10.0" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Maturity Date <span class="text-danger">*</span></label>
                    <input asp-for="MaturityDate" class="form-control" type="date" />
                    <span asp-validation-for="MaturityDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Holding Bank</label>
                    <input asp-for="HoldingBank" class="form-control" placeholder="e.g. KCB Bank" />
                </div>
                <div class="col-12">
                    <label class="form-label">Account Number</label>
                    <input asp-for="HoldingAccount" class="form-control" placeholder="Account holding the cash" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-navy px-4"><i class="bi bi-safe2 me-1"></i>Record Cash Cover</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div></div>
</form>
</div>
