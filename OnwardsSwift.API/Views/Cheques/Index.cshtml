@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Cheque Discounting Portfolio";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold text-navy mb-0">Cheque Discounting</h1>
        <p class="text-muted small">Portfolio overview of advanced post-dated cheques</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
        <i class="bi bi-plus-lg me-2"></i>New Application
    </a>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex align-items-center">
                <div class="bg-primary-subtle text-primary p-3 rounded-3 me-3">
                    <i class="bi bi-wallet2 fs-4"></i>
                </div>
                <div>
                    <div class="text-muted extra-small fw-bold text-uppercase">Total Portfolio</div>
                    <div class="h5 mb-0 fw-bold">KES @Model.Sum(x => (decimal)x.ChequeAmount).ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex align-items-center">
                <div class="bg-warning-subtle text-warning p-3 rounded-3 me-3">
                    <i class="bi bi-clock-history fs-4"></i>
                </div>
                <div>
                    <div class="text-muted extra-small fw-bold text-uppercase">Awaiting Approval</div>
                    <div class="h5 mb-0 fw-bold">@Model.Count(x => x.Status == "Awaiting Approval")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light extra-small text-uppercase text-muted">
                <tr>
                    <th class="ps-4">Client / Company</th>
                    <th>Cheque Info</th>
                    <th>Value Details</th>
                    <th>Maturity</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-navy">@item.ClientName</div>
                            <div class="extra-small text-muted">Ref: #@item.Id</div>
                        </td>
                        <td>
                            <div class="small fw-bold">@item.ChequeNumber</div>
                            <div class="extra-small text-muted">@item.DrawerBank</div>
                        </td>
                        <td>
                            <div class="small">Gross: <span class="fw-bold">KES @item.ChequeAmount.ToString("N2")</span></div>
                            <div class="extra-small text-success">Net Advance: KES @item.AdvanceAmount.ToString("N2")</div>
                        </td>
                        <td>
                            @{
                                var daysToMaturity = (item.ExpiryDate - DateTime.Now).Days;
                                var textClass = daysToMaturity < 0 ? "text-danger" : (daysToMaturity <= 7 ? "text-warning" : "text-dark");
                            }
                            <div class="small fw-bold @textClass">@item.ExpiryDate.ToString("dd MMM yyyy")</div>
                            <div class="extra-small text-muted">
                                @(daysToMaturity < 0 ? "Matured" : daysToMaturity + " days remaining")
                            </div>
                        </td>
                        <td>
                            @if (item.Status == "Awaiting Approval")
                            {
                                <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning-subtle px-3">Pending Approval</span>
                            }
                            else if (item.Status == "Released")
                            {
                                <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3">Funds Released</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-light text-dark border px-3">@item.Status</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light border dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    Manage
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    <li><a class="dropdown-item small" href="#"><i class="bi bi-eye me-2"></i>View Details</a></li>
                                    <li><a class="dropdown-item small" href="#"><i class="bi bi-printer me-2"></i>Print Voucher</a></li>
                                    @if (item.Status == "Awaiting Approval")
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item small text-danger" href="#"><i class="bi bi-trash me-2"></i>Cancel</a></li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                            No discounting applications found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>