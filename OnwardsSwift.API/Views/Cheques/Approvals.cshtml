@model IEnumerable<dynamic>

<div class="page-header mb-4">
    <h1 class="h3 fw-bold text-navy">Pending Authorizations</h1>
    <p class="text-muted small">Cheque discounting requests requiring manager verification</p>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light extra-small text-uppercase text-muted">
                <tr>
                    <th class="ps-4">Date Submitted</th>
                    <th>Client / Company</th>
                    <th>Cheque Details</th>
                    <th>Payout Amount</th>
                    <th>Pay Via</th>
                    <th class="text-end pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="small fw-bold">@item.CreatedAt.ToString("dd MMM yyyy")</div>
                            <div class="extra-small text-muted">@item.CreatedAt.ToString("HH:mm")</div>
                        </td>
                        <td>
                            <div class="fw-bold text-navy">@item.CompanyName</div>
                        </td>
                        <td>
                            <div class="small">#@item.ChequeNumber</div>
                            <div class="extra-small text-muted text-uppercase">@item.DrawerBank</div>
                        </td>
                        <td>
                            <div class="fw-bold text-success">KES @item.NetAdvance.ToString("N2")</div>
                            <div class="extra-small text-muted text-decoration-line-through">
                                Gross: @item.ChequeAmount.ToString("N2")
                            </div>
                        </td>
                        <td>
                            @if (item.PaymentMethod == "MPESA")
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="bi bi-phone me-1"></i> M-Pesa
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                    <i class="bi bi-bank me-1"></i> Bank
                                </span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Verify" asp-route-id="@item.Id" class="btn btn-navy btn-sm px-3 shadow-sm">
                                <i class="bi bi-shield-check me-1"></i> Verify & Authorize
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="text-muted">
                                <i class="bi bi-check2-circle fs-1 d-block mb-2 text-success opacity-50"></i>
                                <p class="mb-0">All clear! No pending cheques for approval.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>