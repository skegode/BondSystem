@model OnwardsSwift.Core.DTOs.CreateAdvancePaymentRequest
@{ ViewData["Title"] = "New Advance Payment Bond"; }

<div class="page-header">
    <h1>New Advance Payment Bond</h1>
    <div class="subtitle">Rate: 2.5% p.a.</div>
</div>

<div class="content-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row"><div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header">Contract Details</div>
            <div class="card-body row g-3">
                <div class="col-md-6">
                    <label class="form-label">Client <span class="text-danger">*</span></label>
                    <select asp-for="ClientId" class="form-select" asp-items="ViewBag.Clients">
                        <option value="">-- Select Client --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contract Reference <span class="text-danger">*</span></label>
                    <input asp-for="ContractRef" class="form-control" placeholder="e.g. MLSP/001/2026" />
                    <span asp-validation-for="ContractRef" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Beneficiary <span class="text-danger">*</span></label>
                    <input asp-for="Beneficiary" class="form-control" placeholder="Who receives the bond" />
                    <span asp-validation-for="Beneficiary" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Bond Amount (KSh) <span class="text-danger">*</span></label>
                    <input asp-for="BondAmount" class="form-control" data-amount="true" placeholder="0.00" />
                    <span asp-validation-for="BondAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Bank Rate (%) <span class="text-danger">*</span></label>
                    <input asp-for="BankRate" class="form-control" type="number" step="0.01" placeholder="e.g. 2.5" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Tenor (Days) <span class="text-danger">*</span></label>
                    <input asp-for="TenorDays" class="form-control" type="number" min="1" />
                    <span asp-validation-for="TenorDays" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contract Start Date</label>
                    <input asp-for="ContractStartDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contract End Date</label>
                    <input asp-for="ContractEndDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Payment Mode</label>
                    <select asp-for="PaymentMode" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="Cash">Cash</option>
                        <option value="Cheque">Cheque</option>
                        <option value="BankTransfer">Bank Transfer</option>
                        <option value="MPESA">M-PESA</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-navy px-4">
                <i class="bi bi-send me-1"></i>Submit Application
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div></div>
</form>
</div>
