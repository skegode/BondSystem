@model OnwardsSwift.Core.DTOs.CreateBidBondRequest

@{
    ViewData["Title"] = "Create Bid Bond";
}

<style>
    :root {
        --os-primary: #0d6efd;
        --os-sidebar-bg: #f8f9fa;
    }

    .form-section-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        border-bottom: 2px solid #e9ecef;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
    }

    .card {
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,0.08) !important;
        }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 0.6rem 0.8rem;
        border: 1px solid #dee2e6;
    }

        .form-control:focus {
            border-color: var(--os-primary);
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
        }

    .input-group-text {
        border-radius: 8px;
        background-color: #fff;
    }

    .pricing-card {
        background: linear-gradient(145deg, #ffffff, #f1f4f9);
        border: 1px solid #dee2e6;
    }

    .rate-box {
        background-color: #f0f7ff;
        border: 1px solid #cfe2ff;
        border-radius: 10px;
    }

    .btn-process {
        border-radius: 10px;
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 12px;
    }

    .payment-kv {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.95rem;
        padding: 0.35rem 0;
        border-bottom: 1px solid #eef1f4;
    }

    .payment-kv:last-of-type {
        border-bottom: 0;
    }
</style>

<div class="container-fluid py-4 px-lg-5">
    <form id="bondForm" method="post" asp-action="Create" enctype="multipart/form-data">
        @await Html.PartialAsync("_ValidationErrors")
        @Html.AntiForgeryToken()

        <input type="hidden" id="hCommissionAmount" asp-for="CommissionAmount" />
        <input type="hidden" id="hApplicationFee" asp-for="ApplicationFee" />
        <input type="hidden" id="hAppliedRate" asp-for="AppliedRate" />
        <input type="hidden" id="hTaxCalculation" asp-for="TaxCalculation" />
        <input type="hidden" id="hTotalBankCharge" asp-for="TotalBankCharge" />
        <input type="hidden" id="hNetProfit" asp-for="NetProfit" />
        <input type="hidden" id="deferredToggle" asp-for="IsDeferredPayment" />

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4 p-lg-5">
                        <h6 class="form-section-title">1. Application Core Details</h6>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Client</label>
                                <select asp-for="ClientId" class="form-select select2" asp-items="ViewBag.Clients" required>
                                    <option value="">-- Select Client --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Agent / Broker</label>
                                <select asp-for="AgentId" class="form-select select2" asp-items="ViewBag.Agents">
                                    <option value="">-- Direct --</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Tender Name / Description</label>
                                <input type="text" asp-for="TenderName" class="form-control" placeholder="e.g. Construction of Modern Office Complex" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Procuring Entity</label>
                                <input type="text" asp-for="ProcuringEntity" class="form-control" placeholder="e.g. Kenya National Highways Authority" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Tender Number</label>
                                <input type="text" asp-for="TenderNumber" class="form-control" placeholder="e.g. KGN-GEN-2026" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Issuing Bank</label>
                                <select id="BankId" asp-for="IssuingBank" class="form-select" asp-items="ViewBag.Banks" required>
                                    <option value="">-- Select Bank --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Bond Product Type</label>
                                <select id="ProductType" asp-for="BondTypeId" class="form-select" asp-items="ViewBag.ProductTypes" required>
                                    <option value="">-- Select Product --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Application Status</label>
                                <select asp-for="ApplicationStatus" id="ApplicationStatus" class="form-select" required>
                                    <option value="New Application">New Application</option>
                                    <option value="Amendment">Amendment</option>
                                    <option value="Extension">Extension</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-dark">Bond Amount (KSh)</label>
                                <div class="input-group">
                                    <span class="input-group-text text-muted small">KES</span>
                                    <input type="number" id="Amount" asp-for="Amount" class="form-control fw-bold text-primary" step="0.01" required />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-dark">Tenor (Days)</label>
                                <input type="number" id="Tenor" asp-for="TenorDays" class="form-control fw-bold" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-dark">Closing Date</label>
                                <input type="date" asp-for="TenderClosingDate" class="form-control text-muted" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-dark">Processing Date</label>
                                <input type="date" asp-for="ProcessingDate" class="form-control text-muted" />
                            </div>
                        </div>

                        <div class="rate-box mt-5 p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h6 class="mb-0 text-primary fw-bold">Annual Interest Rate Control</h6>
                                    <small class="text-muted">Adjust total rate to calculate final premium</small>
                                </div>
                                <div id="rateLoadStatus"></div>
                            </div>
                            <div class="row align-items-center">
                                <div class="col-md-7">
                                    <div class="input-group">
                                        <input type="number" id="uiCombinedRate" class="form-control form-control-lg fw-bold" step="0.001" placeholder="0.000" />
                                        <span class="input-group-text fw-bold text-muted">% p.a.</span>
                                    </div>
                                    <div id="rateWarning" class="text-danger small mt-2 d-none">
                                        <i class="bi bi-info-circle-fill"></i> Rate cannot be lower than bank floor rate.
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="alert alert-secondary mb-0 py-2 small opacity-75">
                                        System calculates bank commission vs. company profit automatically.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4 p-lg-5">
                        <h6 class="form-section-title">2. Support Documentation</h6>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Tender Document / Advert <span class="text-muted fw-normal">(PDF)</span></label>
                                <input type="file" name="TenderDoc" class="form-control" accept=".pdf" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">CR12 / ID Copy</label>
                                <input type="file" name="CR12" class="form-control" accept=".pdf,.jpg,.png" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Payment Receipt <span class="text-muted fw-normal">(if paid)</span></label>
                                <input type="file" name="PaymentReceipt" id="paymentReceiptInput" class="form-control" accept=".pdf,.jpg,.png" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="hasCashCoverToggle" asp-for="HasCashCover">
                                    <label class="form-check-label fw-bold text-dark" for="hasCashCoverToggle">Apply Cash Cover</label>
                                </div>
                                <div id="cashCoverFields" class="row g-3" style="display:none;">
                                    <div class="col-12">
                                        <label class="form-label small fw-bold text-muted">Internal Holding Bank</label>
                                        <select name="CashCoverBankId" class="form-select form-select-sm" asp-items="ViewBag.InternalBanks">
                                            <option value="">-- Select Account --</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small fw-bold text-muted">Amount</label>
                                        <input type="number" asp-for="CashCoverAmount" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small fw-bold text-muted">Due Date</label>
                                        <input type="date" asp-for="CashCoverDueDate" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-bold text-muted">Receipt Attachment</label>
                                        <input type="file" name="CashCoverReceipt" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="deferredToggleUi" @(Model.IsDeferredPayment ? "checked" : "")>
                                    <label class="form-check-label fw-bold text-dark" for="deferredToggleUi">Deferred Payment</label>
                                </div>
                                <div id="paymentFields" class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label small fw-bold text-muted">Internal Payment Bank</label>
                                        <select asp-for="PaymentBankId" class="form-select form-select-sm" asp-items="ViewBag.InternalBanks">
                                            <option value="">-- Select Account --</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-bold text-muted">Reference</label>
                                        <input type="text" id="DeferredPaymentReference" class="form-control form-control-sm" maxlength="100" value="@Model.PaymentReference" />
                                    </div>
                                </div>
                                <div id="deferredFields" class="mt-3" style="display:none;">
                                    <div class="p-3 bg-warning-subtle rounded border border-warning">
                                        <label class="form-label small fw-bold">Settlement Due Date</label>
                                        <input type="date" name="PaymentDueDate" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4 p-lg-5">
                        <h6 class="form-section-title">3. Internal Remarks</h6>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add any specific instructions or client requests here..."></textarea>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow pricing-card border-0 sticky-top" style="top: 2rem;">
                    <div class="card-header bg-white py-3 border-0">
                        <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-receipt me-2"></i>Pricing Summary</h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Client Charge (KES)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">KES</span>
                                <input type="number" asp-for="ClientCharges" id="ClientCharges" class="form-control" step="0.01" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Amendment Fee (KES)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">KES</span>
                                <input type="number" asp-for="AmendmentFee" id="AmendmentFee" class="form-control" step="0.01" min="0" />
                            </div>
                            <small class="text-muted">When status is Amendment, this value is used as the client charge.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Bank Charge (KES)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">KES</span>
                                <input type="number" asp-for="BankCharges" id="BankCharges" class="form-control" step="0.01" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Tax Percentage (%)</label>
                            <div class="input-group">
                                <input type="number" asp-for="TaxPercentage" id="TaxPercentage" class="form-control" step="0.01" value="20.00" readonly />
                                <span class="input-group-text bg-light">%</span>
                            </div>
                            <small class="text-muted">Fixed tax rate: 20%</small>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Tax Calculation</span>
                            <span id="sideTaxCalculation" class="fw-semibold">KES 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Total Bank Charge</span>
                            <span id="sideBankCharge" class="fw-semibold">KES 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted small">Net Profit</span>
                            <span id="sideNetProfit" class="text-success fw-bold">KES 0.00</span>
                        </div>

                        <div class="bg-white p-4 rounded-4 border text-center mb-4 shadow-sm">
                            <label class="text-muted small text-uppercase fw-bold mb-1 d-block" style="letter-spacing: 1px;">Estimated Premium</label>
                            <h2 class="mb-0 text-dark fw-bold" id="sideTotalDisplay">0.00</h2>
                            <small class="text-muted">Total including bank commission</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-primary">Negotiated Premium Override</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-success">KES</span>
                                <input type="number" id="sideTotal2" class="form-control border-success fw-bold" step="0.01" />
                            </div>
                        </div>

                        <div class="pt-2 mt-2" style="border-top:1px solid #e9ecef;">
                            <div class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing:.08em;">Payment Status</div>
                            <div class="mb-3">
                                <span id="paymentStatusBadge" class="badge bg-warning text-dark"><i class="bi bi-x-circle me-1"></i>Unpaid</span>
                            </div>

                            <div class="payment-kv">
                                <span class="fw-semibold text-muted">Total Charged</span>
                                <span id="totalChargedView" class="fw-bold">KES 0.00</span>
                            </div>
                            <div class="payment-kv">
                                <span class="fw-semibold text-muted">Total Paid</span>
                                <span id="totalPaidView" class="fw-bold text-success">KES 0.00</span>
                            </div>
                            <div class="payment-kv mb-2">
                                <span class="fw-semibold text-muted">Outstanding</span>
                                <span id="outstandingView" class="fw-bold text-danger">KES 0.00</span>
                            </div>

                            <div class="small text-muted mb-3">
                                <div><strong>Reference:</strong> <span id="paymentRefPreview">—</span></div>
                                <div><strong>Method:</strong> <span id="paymentMethodPreview">—</span></div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-12">
                                    <label class="form-label small fw-bold text-muted">Set Status</label>
                                    <select id="PaymentStatus" asp-for="IsPaid" class="form-select form-select-sm">
                                        <option value="false" selected="@(Model.IsPaid ? null : "selected")">Unpaid</option>
                                        <option value="true" selected="@(Model.IsPaid ? "selected" : null)">Paid</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-bold text-muted">Amount paid (optional)</label>
                                    <input type="number" id="AmountPaid" asp-for="AmountPaid" class="form-control form-control-sm" step="0.01" min="0" placeholder="Amount paid (optional)" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-bold text-muted">Payment reference</label>
                                    <input type="text" id="PaymentReference" asp-for="PaymentReference" class="form-control form-control-sm" maxlength="100" placeholder="Payment reference" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-bold text-muted">Select payment method</label>
                                    <select id="PaymentMethod" asp-for="PaymentMethod" class="form-select form-select-sm">
                                        <option value="">Select payment method</option>
                                        <option value="MPESA">Mpesa</option>
                                        <option value="BANK">Bank</option>
                                        <option value="CHEQUE">Cheque</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-bold text-muted">Notes (optional)</label>
                                    <textarea id="PaymentNotes" asp-for="PaymentNotes" class="form-control form-control-sm" rows="2" maxlength="300" placeholder="Notes (optional)"></textarea>
                                </div>
                            </div>
                        </div>

                        <button type="submit" id="submitBtn" class="btn btn-primary btn-process w-100 shadow">
                            CREATE APPLICATION <i class="bi bi-arrow-right-circle ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function() {
            let bankFloorRate = 0;
            const el = id => document.getElementById(id);
            const fmt = val => new Intl.NumberFormat('en-KE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);

            function isAmendment() {
                return (el("ApplicationStatus")?.value || "").trim() === "Amendment";
            }

            function syncApplicationStatusPricing() {
                const clientChargesInput = el("ClientCharges");
                const amendmentFeeInput = el("AmendmentFee");
                if (!clientChargesInput || !amendmentFeeInput) return;

                if (isAmendment()) {
                    const amendmentFee = parseFloat(amendmentFeeInput.value) || 0;
                    clientChargesInput.value = amendmentFee.toFixed(2);
                    clientChargesInput.readOnly = true;
                    clientChargesInput.classList.add("bg-light");
                } else {
                    clientChargesInput.readOnly = false;
                    clientChargesInput.classList.remove("bg-light");
                }
            }

            function updatePricingSummary() {
                syncApplicationStatusPricing();

                const clientCharge = parseFloat(el("ClientCharges")?.value) || 0;
                const bankCharge = parseFloat(el("BankCharges")?.value) || 0;
                const taxPercentage = parseFloat(el("TaxPercentage")?.value) || 0;

                const taxCalculation = bankCharge * (taxPercentage / 100);
                const totalBankCharge = bankCharge + taxCalculation;
                const netProfit = clientCharge - totalBankCharge;

                el("sideTaxCalculation").textContent = "KES " + fmt(taxCalculation);
                el("sideBankCharge").textContent = "KES " + fmt(totalBankCharge);
                el("sideNetProfit").textContent = "KES " + fmt(netProfit);

                el("hTaxCalculation").value = taxCalculation.toFixed(2);
                el("hTotalBankCharge").value = totalBankCharge.toFixed(2);
                el("hNetProfit").value = netProfit.toFixed(2);

                // Persist net profit for DB and reporting commission base.
                el("hApplicationFee").value = netProfit.toFixed(2);
                el("hCommissionAmount").value = clientCharge.toFixed(2);
                updatePaymentSummary();
            }

            function updatePaymentSummary() {
                const totalCharged = parseFloat(el("ClientCharges")?.value) || 0;
                const amountPaidInput = el("AmountPaid");
                const statusSelect = el("PaymentStatus");
                const statusBadge = el("paymentStatusBadge");

                let amountPaid = parseFloat(amountPaidInput?.value) || 0;
                if (amountPaid < 0) amountPaid = 0;

                if (totalCharged > 0 && amountPaid > totalCharged) {
                    amountPaid = totalCharged;
                    amountPaidInput.value = totalCharged.toFixed(2);
                }

                const isPaidSelected = statusSelect?.value === "true";
                if (isPaidSelected && amountPaid === 0 && totalCharged > 0) {
                    amountPaid = totalCharged;
                    amountPaidInput.value = totalCharged.toFixed(2);
                }

                const outstanding = Math.max(totalCharged - amountPaid, 0);
                const unpaid = outstanding > 0 || !isPaidSelected;

                el("totalChargedView").textContent = "KES " + fmt(totalCharged);
                el("totalPaidView").textContent = "KES " + fmt(amountPaid);
                el("outstandingView").textContent = "KES " + fmt(outstanding);
                el("outstandingView").classList.toggle("text-danger", outstanding > 0);
                el("outstandingView").classList.toggle("text-success", outstanding <= 0);

                if (unpaid) {
                    statusBadge.className = "badge bg-warning text-dark";
                    statusBadge.innerHTML = '<i class="bi bi-x-circle me-1"></i>Unpaid';
                } else {
                    statusBadge.className = "badge bg-success-subtle text-success border border-success-subtle";
                    statusBadge.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Paid';
                }

                const paymentReference = el("PaymentReference")?.value?.trim();
                const paymentMethod = el("PaymentMethod")?.value;
                el("paymentRefPreview").textContent = paymentReference ? paymentReference : "—";
                el("paymentMethodPreview").textContent = paymentMethod ? paymentMethod : "—";

                el("deferredToggle").value = unpaid ? "true" : "false";
                syncDeferredModule(unpaid);
            }

            function syncDeferredModule(isDeferred) {
                const deferredToggleUi = el("deferredToggleUi");
                const paymentFields = el("paymentFields");
                const deferredFields = el("deferredFields");

                if (deferredToggleUi) deferredToggleUi.checked = isDeferred;
                if (paymentFields) paymentFields.style.display = isDeferred ? "none" : "flex";
                if (deferredFields) deferredFields.style.display = isDeferred ? "block" : "none";
            }

            function runCalc(triggerId) {
                const principal = parseFloat(el("Amount").value) || 0;
                const days      = parseInt(el("Tenor").value)    || 0;
                let combined    = parseFloat(el("uiCombinedRate").value) || 0;

                if (principal <= 0 || days <= 0) return;

                const effectiveBankRate = combined >= bankFloorRate ? bankFloorRate : combined;
                const profitRate        = Math.max(0, combined - bankFloorRate);

                const bankCharge   = principal * (effectiveBankRate / 100) * (days / 365);
                const profitAmount = principal * (profitRate / 100) * (days / 365);
                const total        = bankCharge + profitAmount;

                // default client/bank charges
                if (!el("ClientCharges").value && !isAmendment()) el("ClientCharges").value = (profitAmount + bankCharge).toFixed(2);
                if (!el("BankCharges").value) el("BankCharges").value = bankCharge.toFixed(2);
                el("hAppliedRate").value      = combined.toFixed(3);

                el("sideTotalDisplay").textContent = fmt(total);

                if (triggerId !== 'sideTotal2') el("sideTotal2").value = total.toFixed(2);
                updatePricingSummary();

                const isLoss = combined < bankFloorRate && combined > 0;
                el("rateWarning").classList.toggle("d-none", !isLoss);
                el("submitBtn").disabled = isLoss;
            }

            function backCalculate() {
                const principal = parseFloat(el("Amount").value) || 0;
                const days      = parseInt(el("Tenor").value)    || 0;
                const premium   = parseFloat(el("sideTotal2").value) || 0;
                if (principal > 0 && days > 0 && premium > 0) {
                    const rate = (premium * 365 * 100) / (principal * days);
                    el("uiCombinedRate").value = rate.toFixed(3);
                    runCalc('sideTotal2');
                }
            }

            async function loadRates() {
                const bankId = el("BankId").value;
                const prodType = el("ProductType").value;
                if (!bankId || !prodType) return;
                el("rateLoadStatus").innerHTML = '<div class="spinner-grow spinner-grow-sm text-primary"></div>';
                try {
        const r = await fetch(`@Url.Action("GetLiveRate", "BidBonds")?bankId=${bankId}&productType=${prodType}`);
        const d = await r.json();
                    if (d.error === 'unauthorized') { window.location.href = '@Url.Action("Login", "Account")'; return; }
                    bankFloorRate = parseFloat(d.rate) || 0;
                    el("uiCombinedRate").value = (bankFloorRate + (parseFloat(d.appFee) || 0)).toFixed(3);
                    el("rateLoadStatus").innerHTML = `<span class="badge rounded-pill bg-primary px-3">Floor: ${bankFloorRate.toFixed(3)}%</span>`;
                    runCalc();
                } catch (e) { el("rateLoadStatus").innerHTML = '<span class="text-danger small">Load Error</span>'; }
            }

            document.addEventListener("DOMContentLoaded", function() {
                el("TaxPercentage").value = "20.00";
                ["Amount", "Tenor", "uiCombinedRate"].forEach(id => {
                    el(id).addEventListener("input", () => runCalc(id));
                });
                ["ClientCharges", "BankCharges"].forEach(id => {
                    el(id).addEventListener("input", updatePricingSummary);
                });
                if (el("AmendmentFee")) {
                    el("AmendmentFee").addEventListener("input", updatePricingSummary);
                }
                if (el("ApplicationStatus")) {
                    el("ApplicationStatus").addEventListener("change", () => {
                        updatePricingSummary();
                    });
                }
                el("PaymentStatus").addEventListener("change", updatePaymentSummary);
                el("AmountPaid").addEventListener("input", updatePaymentSummary);
                el("PaymentReference").addEventListener("input", updatePaymentSummary);
                el("PaymentMethod").addEventListener("change", updatePaymentSummary);

                if (el("DeferredPaymentReference")) {
                    el("DeferredPaymentReference").addEventListener("input", function() {
                        el("PaymentReference").value = this.value;
                        updatePaymentSummary();
                    });
                }

                if (el("deferredToggleUi")) {
                    el("deferredToggleUi").addEventListener("change", function() {
                        const totalCharged = parseFloat(el("ClientCharges")?.value) || 0;
                        if (this.checked) {
                            el("PaymentStatus").value = "false";
                            el("AmountPaid").value = "0";
                        } else {
                            el("PaymentStatus").value = "true";
                            if (totalCharged > 0) {
                                el("AmountPaid").value = totalCharged.toFixed(2);
                            }
                        }
                        updatePaymentSummary();
                    });
                }

                el("sideTotal2").addEventListener("input", backCalculate);
                el("BankId").addEventListener("change", loadRates);
                el("ProductType").addEventListener("change", loadRates);

                el("hasCashCoverToggle").addEventListener("change", function() {
                    el("cashCoverFields").style.display = this.checked ? "flex" : "none";
                });

                updatePricingSummary();
                if (el("DeferredPaymentReference") && el("PaymentReference")?.value) {
                    el("DeferredPaymentReference").value = el("PaymentReference").value;
                }
                updatePaymentSummary();
                runCalc();
            });
        })();
    </script>
}