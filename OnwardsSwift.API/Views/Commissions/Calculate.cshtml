@model List<OnwardsSwift.Core.DTOs.UserCommissionSummaryForPayment>
@{
    ViewData["Title"] = "Calculate Commissions";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1 text-navy">Calculate Commissions</h1>
        <p class="text-muted mb-0">Review and create commission payment records for the selected month.</p>
    </div>
    <a href="@Url.Action("Payments", "Commissions")" class="btn btn-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Payments
    </a>
</div>

<!-- Month Selection -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light border-0 py-3">
        <h6 class="mb-0 fw-bold text-navy">Select Month for Calculation</h6>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label fw-bold">Month</label>
                <select name="month" class="form-select" required>
                    <option value="">Select Month</option>
                    @for (int i = 1; i <= 12; i++)
                    {
                        var isSelected = ViewBag.SelectedMonth == i ? "selected" : "";
                        <option value="@i" selected="@isSelected">@i.ToString("D2")</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Year</label>
                <input type="number" name="year" value="@(ViewBag.SelectedYear ?? DateTime.Now.Year)" class="form-control" required />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-navy">View Commissions</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <!-- Summary Table -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0 fw-bold text-navy">Commission Summary for Period @(ViewBag.SelectedMonth):00/@ViewBag.SelectedYear</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small text-muted">
                    <tr>
                        <th class="ps-4">User</th>
                        <th class="text-end">Base</th>
                        <th class="text-end">Commission %</th>
                        <th class="text-end">Commission Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@item.UserName</td>
                            <td class="text-end">KES @item.CommissionBase.ToString("N2")</td>
                            <td class="text-end">@item.CommissionPercent.ToString("N2")%</td>
                            <td class="text-end fw-bold text-success">KES @item.CommissionAmount.ToString("N2")</td>
                        </tr>
                    }
                    <tr class="table-info fw-bold">
                        <td class="ps-4">TOTAL</td>
                        <td class="text-end">KES @Model.Sum(x => x.CommissionBase).ToString("N2")</td>
                        <td></td>
                        <td class="text-end">KES @Model.Sum(x => x.CommissionAmount).ToString("N2")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Create Records Button -->
    <div class="row mb-4">
        <div class="col-md-12">
            <form method="post" action="@Url.Action("CreatePayments", "Commissions")" onsubmit="return confirm('This will create commission payment records for @(ViewBag.SelectedMonth):00/@ViewBag.SelectedYear. Continue?');">
                <input type="hidden" name="month" value="@ViewBag.SelectedMonth" />
                <input type="hidden" name="year" value="@ViewBag.SelectedYear" />
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Create Commission Payment Records
                </button>
            </form>
        </div>
    </div>
}
else if (ViewBag.SelectedMonth != null)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No commissions calculated for the selected period.
    </div>
}
