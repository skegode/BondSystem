@model OnwardsSwift.Core.DTOs.InvoiceDiscountResponse
@{ ViewData["Title"] = Model.ReferenceNo; }
<div class="page-header d-flex align-items-center justify-content-between">
    <div><h1>@Model.ReferenceNo</h1><div class="subtitle">@Model.ClientName · Invoice @Model.InvoiceNumber</div></div>
    <span class="badge-status status-@Model.Status.ToLower() fs-6">@Model.Status</span>
</div>
<div class="content-body">
<div class="row g-3">
<div class="col-md-4">
    <div class="card mb-3">
        <div class="card-header">Invoice Summary</div>
        <div class="card-body">
            <dl class="row mb-0 small">
                <dt class="col-5 text-muted">Client</dt><dd class="col-7">@Model.ClientName</dd>
                <dt class="col-5 text-muted">Debtor</dt><dd class="col-7">@Model.DebtorName</dd>
                <dt class="col-5 text-muted">Invoice No.</dt><dd class="col-7">@Model.InvoiceNumber</dd>
                <dt class="col-5 text-muted">Face Value</dt><dd class="col-7 fw-bold">KSh @Model.InvoiceFaceValue.ToString("N2")</dd>
                <dt class="col-5 text-muted">Advance %</dt><dd class="col-7">@Model.AdvancePercentage%</dd>
                <dt class="col-5 text-muted">Advance Amt</dt><dd class="col-7 text-primary fw-bold">KSh @Model.AdvanceAmount.ToString("N2")</dd>
                <dt class="col-5 text-muted">Discount Fee</dt><dd class="col-7">KSh @Model.DiscountFee.ToString("N2")</dd>
                <dt class="col-5 text-muted">Net to Client</dt><dd class="col-7 text-success fw-bold">KSh @Model.NetAdvance.ToString("N2")</dd>
                <dt class="col-5 text-muted">Invoice Date</dt><dd class="col-7">@Model.InvoiceDate.ToString("dd MMM yyyy")</dd>
                <dt class="col-5 text-muted">Due Date</dt><dd class="col-7">@Model.InvoiceDueDate.ToString("dd MMM yyyy")</dd>
                <dt class="col-5 text-muted">Debtor Paid</dt>
                <dd class="col-7">@(Model.DebtorPaid ? "<span class='text-success'>Yes</span>" : "<span class='text-warning'>No</span>")</dd>
            </dl>
        </div>
    </div>
    @if (Model.Status is "Pending" or "UnderReview") {
    <div class="card mb-3">
        <div class="card-header">Actions</div>
        <div class="card-body d-grid gap-2">
            <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#approveModal">Approve</button>
            <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">Reject</button>
        </div>
    </div>
    }
    @if (Model.Status == "Approved") {
    <div class="card mb-3">
        <div class="card-header">Disburse</div>
        <div class="card-body">
            <form asp-action="Disburse" asp-route-id="@Model.FacilityId" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-navy w-100">Disburse KSh @Model.NetAdvance.ToString("N0")</button>
            </form>
        </div>
    </div>
    }
    @if (Model.Status == "Disbursed" && !Model.DebtorPaid) {
    <div class="card">
        <div class="card-header">Record Debtor Payment</div>
        <form asp-action="RecordPayment" asp-route-id="@Model.FacilityId" method="post">
            @Html.AntiForgeryToken()
            <div class="card-body row g-2">
                <div class="col-12"><input name="paymentAmount" class="form-control form-control-sm" type="number" step="0.01" placeholder="Amount received" required /></div>
                <div class="col-12"><input name="paymentDate" class="form-control form-control-sm" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required /></div>
            </div>
            <div class="card-footer">
                <button class="btn btn-sm btn-success w-100">Record Payment</button>
            </div>
        </form>
    </div>
    }
</div>
</div>
</div>
<div class="modal fade" id="approveModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title">Approve Facility</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <form asp-action="Approve" asp-route-id="@Model.FacilityId" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-body"><textarea name="notes" class="form-control" rows="2" placeholder="Notes (optional)"></textarea></div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-success">Approve</button></div>
    </form>
</div></div></div>
<div class="modal fade" id="rejectModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title">Reject Facility</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <form asp-action="Reject" asp-route-id="@Model.FacilityId" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-body"><textarea name="reason" class="form-control" rows="3" placeholder="Reason" required></textarea></div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-danger">Reject</button></div>
    </form>
</div></div></div>