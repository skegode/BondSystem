@model List<OnwardsSwift.Core.DTOs.WorkflowStageViewModel>
@{
    ViewData["Title"] = "Workflow Configuration";
    string activeModule = ViewBag.ActiveModule ?? "BOND";
}

<div class="container-fluid py-4">
    <div class="row mb-4 animate__animated animate__fadeIn">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 fw-bold text-navy mb-1">Approval Workflow Designer</h1>
                <p class="text-muted small">Drag and drop personnel to build your approval hierarchy for <strong>@activeModule</strong>.</p>
            </div>
            <button class="btn btn-navy px-4 shadow-sm" onclick="showAddModal()">
                <i class="bi bi-plus-lg me-2"></i>Add New Stage
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <ul class="nav nav-tabs nav-fill bg-light border-bottom-0">
                <li class="nav-item">
                    <a class="nav-link py-3 @(activeModule == "BOND" ? "active fw-bold border-top-navy text-navy" : "text-muted")" asp-action="Configure" asp-route-module="BOND">
                        <i class="bi bi-file-earmark-check me-2"></i>Bonds & Guarantees
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link py-3 @(activeModule == "CHEQUE" ? "active fw-bold border-top-navy text-navy" : "text-muted")" asp-action="Configure" asp-route-module="CHEQUE">
                        <i class="bi bi-bank me-2"></i>Cheque Discounting
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link py-3 @(activeModule == "CASH" ? "active fw-bold border-top-navy text-navy" : "text-muted")" asp-action="Configure" asp-route-module="CASH">
                        <i class="bi bi-safe me-2"></i>Cash Covers
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase extra-small fw-bold">
                    <tr>
                        <th class="ps-4" style="width: 100px;">Sequence</th>
                        <th>Stage Name</th>
                        <th>Authorized Approvers</th>
                        <th class="text-center">Final Step</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stage in Model.OrderBy(x => x.SequenceOrder))
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="bg-navy text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px;">
                                    @stage.SequenceOrder
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold text-dark d-block">@stage.StageName</span>
                            </td>
                            <td>
                                @foreach (var user in stage.Approvers)
                                {
                                    <span class="badge bg-navy- Pilgrim text-navy border border-navy-subtle rounded-pill me-1 px-2 py-1">
                                        @user.FullName <small class="opacity-75">(@user.Role)</small>
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (stage.IsFinalStage)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">FINAL</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-2" onclick='editStage(@Json.Serialize(new { id = stage.Id, stageName = stage.StageName, sequenceOrder = stage.SequenceOrder, isFinalStage = stage.IsFinalStage, userIds = stage.Approvers.Select(a => a.Id).ToList() }))'>
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="stageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form asp-action="SaveStage" method="post" id="stageForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="StageId" value="0" />
                <input type="hidden" name="ModuleType" value="@activeModule" />

                <div class="modal-header bg-navy text-white">
                    <h5 class="modal-title" id="modalTitle">Workflow Stage Builder</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-7">
                            <label class="form-label fw-bold small text-uppercase">Stage Name</label>
                            <input type="text" name="StageName" id="StageName" class="form-control" placeholder="e.g. Risk Assessment" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small text-uppercase">Sequence</label>
                            <input type="number" name="SequenceOrder" id="SequenceOrder" class="form-control" required />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="IsFinalStage" id="IsFinalStage" value="true">
                                <label class="form-check-label small fw-bold" for="IsFinalStage">Final?</label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-muted">Available Staff</label>
                            <div class="card shadow-none border bg-light">
                                <div class="list-group list-group-flush sortable-list" id="availableList" style="height: 300px; overflow-y: auto;">
                                    @if (ViewBag.UserList != null)
                                    {
                                        foreach (var user in ViewBag.UserList)
                                        {
                                            <div class="list-group-item d-flex align-items-center grab" data-id="@user.Id">
                                                <i class="bi bi-grip-vertical me-2 text-muted"></i>
                                                <div>
                                                    <div class="fw-bold small">@user.FullName</div>
                                                    <div class="extra-small text-muted">@user.Role</div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-navy">Assigned Approvers</label>
                            <div class="card shadow-none border border-navy bg-white">
                                <div class="list-group list-group-flush sortable-list" id="selectedList" style="height: 300px; overflow-y: auto;">
                                </div>
                                <select name="UserIds" id="HiddenUserIds" multiple hidden required></select>
                            </div>
                            <small class="text-muted mt-2 d-block small italic">Drag users here to assign them.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-navy px-4">Update Workflow</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --navy: #002D72;
    }

    .bg-navy {
        background-color: var(--navy) !important;
    }

    .text-navy {
        color: var(--navy) !important;
    }

    .btn-navy {
        background-color: var(--navy);
        color: white;
    }

        .btn-navy:hover {
            background-color: #001a44;
            color: white;
        }

    .border-navy {
        border-color: var(--navy) !important;
    }

    .grab {
        cursor: grab;
        transition: background 0.2s;
    }

        .grab:active {
            cursor: grabbing;
        }

    .sortable-ghost {
        opacity: 0.4;
        background: #eef2f7;
        border: 2px dashed var(--navy);
    }

    .extra-small {
        font-size: 0.7rem;
    }

    .border-top-navy {
        border-top: 4px solid var(--navy) !important;
    }

    .bg-navy-subtle {
        background-color: #eef2f7 !important;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const availEl = document.getElementById('availableList');
            const selectEl = document.getElementById('selectedList');

            // Initialize Sortable for both lists
            new Sortable(availEl, {
                group: 'approvers',
                animation: 150,
                sort: false // Don't allow reordering in the source list
            });

            new Sortable(selectEl, {
                group: 'approvers',
                animation: 150,
                onSort: function () { updateHiddenInputs(); }
            });

            function updateHiddenInputs() {
                const select = document.getElementById('HiddenUserIds');
                select.innerHTML = '';
                [...selectEl.children].forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = item.getAttribute('data-id');
                    opt.selected = true;
                    select.appendChild(opt);
                });
            }

            window.showAddModal = function() {
                document.getElementById('StageId').value = 0;
                document.getElementById('StageName').value = '';
                document.getElementById('IsFinalStage').checked = false;
                selectEl.innerHTML = '';
                updateHiddenInputs();
                document.getElementById('modalTitle').innerText = "Add New Stage";
                $('#stageModal').modal('show');
            }

            window.editStage = function(data) {
                document.getElementById('StageId').value = data.id;
                document.getElementById('StageName').value = data.stageName;
                document.getElementById('SequenceOrder').value = data.sequenceOrder;
                document.getElementById('IsFinalStage').checked = data.isFinalStage;

                // Reset lists
                selectEl.innerHTML = '';
                data.userIds.forEach(id => {
                    const userNode = availEl.querySelector(`[data-id="${id}"]`);
                    if (userNode) {
                        const clone = userNode.cloneNode(true);
                        selectEl.appendChild(clone);
                    }
                });

                updateHiddenInputs();
                document.getElementById('modalTitle').innerText = "Edit Stage";
                $('#stageModal').modal('show');
            }
        });
    </script>
}