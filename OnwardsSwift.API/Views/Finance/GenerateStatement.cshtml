@model IEnumerable<dynamic>
@{
    var client = ViewBag.Client;
    string clientName = Convert.ToString(client?.Name) ?? string.Empty;
    ViewData["Title"] = "Statement - " + clientName;
    string dateFrom = ((DateTime)ViewBag.From).ToString("yyyy-MM-dd");
    string dateTo = ((DateTime)ViewBag.To).ToString("yyyy-MM-dd");
    var selectedBondTypeIds = new HashSet<string>(((ViewBag.SelectedBondTypeIds as List<int>) ?? new List<int>()).Select(x => x.ToString()));
    string contactPerson = Convert.ToString(client?.ContactPerson) ?? string.Empty;
    string clientEmail = Convert.ToString(client?.Email) ?? string.Empty;
    string clientPhone = Convert.ToString(client?.PhoneNumber) ?? string.Empty;
    string kraPin = Convert.ToString(client?.KraPin) ?? string.Empty;
    string businessRegNumber = Convert.ToString(client?.BusinessRegNumber) ?? string.Empty;
    string physicalAddress = Convert.ToString(client?.PhysicalAddress) ?? string.Empty;
    string postalAddress = Convert.ToString(client?.PostalAddress) ?? string.Empty;
}

<style>
    /* Professional PDF/Print Styles */
    @@media print {
        .no-print, .filter-bar
    {
        display: none !important;
    }
    .sidebar {
        display: none !important;
    }
    .main-content {
        margin-left: 0 !important;
        padding: 0 !important;
        width: 100% !important;
    }
    .card {
        border: none !important;
        box-shadow: none !important;
    }
    body {
        background-color: white !important;
    }
    }
    .filter-bar {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e9ecef;
    }
    .table-statement thead {
        background-color: #f8f9fa;
        border-top: 2px solid #333;
    }
    .bof-row {
        background-color: #fafafa;
        font-style: italic;
    }
    .brand-logo {
        max-height: 92px;
        width: auto;
        object-fit: contain;
    }

    .statement-sheet {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
    }

    .statement-meta {
        font-size: 0.92rem;
        line-height: 1.6;
    }

    .client-card,
    .summary-card,
    .signature-card {
        border: 1px solid #e9ecef;
        border-radius: 14px;
        background: #fff;
    }

    .client-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem 1.25rem;
    }

    .client-detail-label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 0.15rem;
    }

    .client-detail-value {
        color: #212529;
        font-weight: 600;
        word-break: break-word;
    }

    .statement-table thead th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }

    .payment-row td {
        background: #f8fbff;
        font-size: 0.92rem;
    }

    .payment-item {
        padding-left: 1.5rem;
        position: relative;
        color: #0d6efd;
        font-weight: 600;
    }

    .payment-item::before {
        content: "";
        position: absolute;
        left: 0.45rem;
        top: 50%;
        width: 0.55rem;
        height: 1px;
        background: #0d6efd;
    }

    .signature-line {
        height: 52px;
        border-bottom: 1px solid #212529;
        margin-bottom: 0.5rem;
    }

    @@media (max-width: 767.98px) {
        .client-detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm mb-4 no-print">
        <div class="card-body p-3">
            <div class="row align-items-start">
                <div class="col-lg-2 mb-2 mb-lg-0">
                    <button onclick="history.back()" class="btn btn-light btn-sm w-100">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                </div>
                <div class="col-lg-7 mb-2 mb-lg-0">
                    <form method="get" asp-action="GenerateStatement" class="row g-2 align-items-start" id="filterForm">
                        <input type="hidden" name="clientId" value="@ViewBag.ClientId" />
                        <div class="col-auto">
                            <span class="small fw-bold text-muted">Filter:</span>
                        </div>
                        <div class="col-md-3">
                            <input type="date" name="from" value="@dateFrom" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <input type="date" name="to" value="@dateTo" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-2 bg-white" style="font-size:0.8rem;">
                                @foreach (var pt in ViewBag.ProductTypeList)
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="bondTypeIds" value="@pt.Id" id="fpt_@pt.Id"
                                               @(selectedBondTypeIds.Contains(((int)pt.Id).ToString()) ? "checked" : "") />
                                        <label class="form-check-label" for="fpt_@pt.Id">@pt.ProductName</label>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-md-1">
                            <button type="submit" class="btn btn-primary btn-sm w-100">Apply</button>
                        </div>
                    </form>
                </div>
                <div class="col-lg-3 text-end">
                    <a id="btnPdf" href="#" class="btn btn-danger btn-sm">
                        <i class="bi bi-file-earmark-pdf"></i> PDF
                    </a>
                    <a id="btnInvoicePdf" href="#" class="btn btn-outline-dark btn-sm ms-1">
                        <i class="bi bi-receipt"></i> Invoice Preview
                    </a>
                    <button onclick="window.print()" class="btn btn-outline-dark btn-sm">
                        <i class="bi bi-printer"></i>
                    </button>
                    <button id="btnExcel" class="btn btn-success btn-sm ms-1">
                        <i class="bi bi-file-earmark-excel"></i> Excel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-4 p-lg-5 statement-sheet" id="printableArea">
        <!-- watermark removed as requested -->

        <div class="row mb-5">
            <div class="col-md-6 d-flex align-items-start">
                <img src="@Url.Content("~/images/onwards-logo.jpg")" alt="Onwards Swift" class="brand-logo" />
            </div>
            <div class="col-md-6 text-md-end mt-4 mt-md-0 statement-meta">
                <div class="fw-bold text-uppercase fs-5 mb-2">Statement</div>
                <div>IPS Building, 4th Floor</div>
                <div>Kimathi Street, Nairobi CBD</div>
                <div>P.O Box 104322-00100 NRB</div>
                <div>Website: onwardsswift.com</div>
                <div class="text-muted mt-3">Period: <strong>@ViewBag.From.ToString("dd-MMM-yyyy")</strong> to <strong>@ViewBag.To.ToString("dd-MMM-yyyy")</strong></div>
                <div class="text-muted">Generated on: @DateTime.Now.ToString("dd-MMM-yyyy HH:mm")</div>
            </div>
        </div>

        <div class="client-card p-4 mb-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <label class="text-muted small text-uppercase fw-bold">Statement For</label>
                    <h5 class="fw-bold text-dark mb-0">@clientName</h5>
                </div>
                <div class="summary-card px-4 py-3 text-end">
                    <div class="small text-muted text-uppercase fw-bold">Closing Balance</div>
                    <div class="fs-4 fw-bold text-primary">KES @ViewBag.TotalDue.ToString("N2")</div>
                    <div class="small text-muted">Brought Forward: KES @ViewBag.Bof.ToString("N2")</div>
                </div>
            </div>

            <div class="client-detail-grid">
                <div>
                    <span class="client-detail-label">Contact Person</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(contactPerson) ? "-" : contactPerson)</span>
                </div>
                <div>
                    <span class="client-detail-label">Phone</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(clientPhone) ? "-" : clientPhone)</span>
                </div>
                <div>
                    <span class="client-detail-label">Email</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(clientEmail) ? "-" : clientEmail)</span>
                </div>
                <div>
                    <span class="client-detail-label">KRA PIN</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(kraPin) ? "-" : kraPin)</span>
                </div>
                <div>
                    <span class="client-detail-label">Business Registration No</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(businessRegNumber) ? "-" : businessRegNumber)</span>
                </div>
                <div>
                    <span class="client-detail-label">Postal Address</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(postalAddress) ? "-" : postalAddress)</span>
                </div>
                <div style="grid-column: 1 / -1;">
                    <span class="client-detail-label">Physical Address</span>
                    <span class="client-detail-value">@(string.IsNullOrWhiteSpace(physicalAddress) ? "-" : physicalAddress)</span>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle statement-table" id="statementTable">
                <thead class="table-light">
                    <tr>
                        <th style="width: 11%">Date</th>
                        <th style="width: 20%">Product Item</th>
                        <th style="width: 16%">Procuring Entity</th>
                        <th class="text-end" style="width: 11%">Bond Amount</th>
                        <th class="text-end" style="width: 11%">Cash Cover</th>
                        <th style="width: 13%">Ref No</th>
                        <th class="text-end" style="width: 9%">Debit</th>
                        <th class="text-end" style="width: 9%">Credit</th>
                        <th class="text-end" style="width: 10%">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="bof-row">
                        <td class="text-muted">@ViewBag.From.ToString("dd-MMM-yyyy")</td>
                        <td><strong>Opening Balance</strong></td>
                        <td>-</td>
                        <td class="text-end">-</td>
                        <td class="text-end">-</td>
                        <td>-</td>
                        <td class="text-end">-</td>
                        <td class="text-end">-</td>
                        <td class="text-end fw-bold">@ViewBag.Bof.ToString("N2")</td>
                    </tr>

                    @foreach (var line in Model)
                    {
                        <tr class="@(line.IsPaymentLine ? "payment-row" : string.Empty)">
                            <td>@line.TransactionDate.ToString("dd-MMM-yyyy")</td>
                            <td>
                                @if (line.IsPaymentLine)
                                {
                                    <span class="payment-item">@line.ProductItem</span>
                                }
                                else
                                {
                                    <span class="fw-semibold">@line.ProductItem</span>
                                }
                            </td>
                            <td>@(!string.IsNullOrWhiteSpace(line.ProcuringEntity) ? line.ProcuringEntity : "-")</td>
                            <td class="text-end">@(line.BondAmount > 0 ? ((decimal)line.BondAmount).ToString("N2") : "-")</td>
                            <td class="text-end">@(line.CashCoverAmount > 0 ? ((decimal)line.CashCoverAmount).ToString("N2") : "-")</td>
                            <td>@(!string.IsNullOrWhiteSpace(line.ReferenceNo) ? line.ReferenceNo : "-")</td>
                            <td class="text-end text-danger">@(line.Debit > 0 ? ((decimal)line.Debit).ToString("N2") : "-")</td>
                            <td class="text-end text-success">@(line.Credit > 0 ? ((decimal)line.Credit).ToString("N2") : "-")</td>
                            <td class="text-end fw-bold">@(((decimal)line.RunningBalance).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-5 g-4 align-items-stretch">
            <div class="col-md-6">
                <div class="signature-card p-4 h-100">
                    <div class="small text-uppercase fw-bold text-muted mb-3">Signature</div>
                    <div class="signature-line"></div>
                    <div class="text-muted small">Authorized Signature</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="signature-card p-4 h-100">
                    <div class="small text-uppercase fw-bold text-muted mb-3">Date</div>
                    <div class="signature-line"></div>
                    <div class="text-muted small">Date Signed</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/gh/linways/table-to-excel@v1.0.4/dist/tableToExcel.js"></script>
    <script>
        $(document).ready(function () {
            var baseUrl = '@Url.Action("GenerateStatement", "Finance")';
            var invoiceUrl = '@Url.Action("GenerateInvoice", "Finance")';
            var clientId = '@ViewBag.ClientId';
            var from = '@dateFrom';
            var to = '@dateTo';

            function buildUrl(action, format) {
                var params = 'clientId=' + clientId + '&from=' + from + '&to=' + to;
                if (format) params += '&format=' + format;
                $('#filterForm input[name="bondTypeIds"]:checked').each(function () {
                    params += '&bondTypeIds=' + encodeURIComponent($(this).val());
                });
                return action + '?' + params;
            }

            $('#btnPdf').click(function (e) {
                e.preventDefault();
                window.location.href = buildUrl(baseUrl, 'pdf');
            });
            $('#btnInvoicePdf').click(function (e) {
                e.preventDefault();
                window.location.href = buildUrl(invoiceUrl, null);
            });

            $("#btnExcel").click(function () {
                let table = document.getElementById("statementTable");
                TableToExcel.convert(table, {
                    name: "Statement_@(string.IsNullOrWhiteSpace(clientName) ? "Client" : clientName.Replace(" ", "_"))" + ".xlsx",
                    sheet: { name: "Transaction History" }
                });
            });
        });
    </script>
}
