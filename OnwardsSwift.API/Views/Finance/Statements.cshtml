@{
    ViewData["Title"] = "Client Statements";
}

<div class="row animate__animated animate__fadeIn">
    <div class="col-md-5 mx-auto">
        <div class="card border-0 shadow-sm mt-5">
            <div class="card-body p-4 text-center">
                <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-file-earmark-text fs-3"></i>
                </div>
                <h4 class="fw-bold">Client Statements</h4>
                <p class="text-muted small">Search for a client to generate a detailed financial statement.</p>

                <hr class="my-4">

                <form asp-action="GenerateStatement" method="get">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold small">Client Selection</label>
                        <select name="clientId" class="form-select select2" required>
                            <option value="">Search Client Name...</option>
                            @* Populate with your clients list *@
                        </select>
                    </div>

                    <div class="row g-2 mb-4">
                        <div class="col-6 text-start">
                            <label class="form-label fw-bold small">From Date</label>
                            <input type="date" name="from" class="form-control" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-6 text-start">
                            <label class="form-label fw-bold small">To Date</label>
                            <input type="date" name="to" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-printer me-2"></i>Generate Statement
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>