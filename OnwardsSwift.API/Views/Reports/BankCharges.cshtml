@model OnwardsSwift.Core.DTOs.BankChargeViewModel
@{
    ViewData["Title"] = "Bank Charges Analysis";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
    <div>
        <h1 class="h3 fw-bold mb-1 text-navy">Bank Charges Analysis</h1>
        <div class="d-flex align-items-center">
            <span class="badge bg-danger me-2">Expense Account</span>
            <p class="text-muted small mb-0 font-monospace">GL: 5005 | BANK_CHARGE_RECON</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button onclick="exportChargesToExcel()" class="btn btn-outline-danger btn-sm px-3 fw-bold">
            <i class="bi bi-file-earmark-excel me-1"></i> Download Recon
        </button>

        <form method="get" class="d-flex gap-2 bg-white p-2 rounded-3 shadow-sm border">
            <div class="input-group input-group-sm border-0">
                <span class="input-group-text bg-transparent border-0"><i class="bi bi-calendar-range"></i></span>
                <input type="date" name="from" value="@(((DateTime)ViewBag.From).ToString("yyyy-MM-dd"))" class="form-control border-0">
                <input type="date" name="to" value="@(((DateTime)ViewBag.To).ToString("yyyy-MM-dd"))" class="form-control border-0">
                <button type="submit" class="btn btn-navy ms-2 rounded-2">Update</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4 animate__animated animate__fadeInUp">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm overflow-hidden h-100">
            <div class="row g-0 h-100">
                <div class="col-4 bg-danger d-flex align-items-center justify-content-center">
                    <i class="bi bi-bank2 text-white display-4"></i>
                </div>
                <div class="col-8">
                    <div class="card-body p-4">
                        <small class="text-uppercase fw-bold text-muted opacity-75">Total Bank Fees Incurred</small>
                        <h1 class="display-6 fw-bold text-danger mb-0">KES @Model.TotalCharges.ToString("N2")</h1>
                        <p class="small text-muted mb-0 mt-2">
                            <i class="bi bi-calculator me-1"></i> Reconciled across @Model.Details.Count line items
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="fw-bold small text-uppercase text-muted mb-3">Charge Concentration</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Max Single Fee</span>
                    <span class="fw-bold text-dark">KES @(Model.Details.Any() ? Model.Details.Max(x => x.Amount).ToString("N2") : "0.00")</span>
                </div>
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar bg-danger" role="progressbar" style="width: 100%"></div>
                </div>
                <div class="mt-3 small text-muted">
                    <i class="bi bi-info-circle-fill text-info me-1"></i>
                    These charges are automatically posted from verified bank settlement files.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm animate__animated animate__fadeInUp">
    <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold text-navy"><i class="bi bi-journal-check me-2"></i>Statement Transaction Detail</h6>
    </div>
    <div class="table-responsive">
        <table id="bankChargesTable" class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white extra-small text-uppercase">
                <tr>
                    <th class="ps-4">Posting Date</th>
                    <th>Reference Info</th>
                    <th>Entity / Beneficiary</th>
                    <th>Narration</th>
                    <th class="text-end pe-4">Cost (KES)</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (Model.Details.Any())
                {
                    foreach (var item in Model.Details)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@item.Date.ToString("dd MMM yyyy")</span>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <small class="fw-bold">Inv: @item.Reference</small>
                                    <small class="text-muted font-monospace extra-small">Bond: @item.BondNumber</small>
                                </div>
                            </td>
                            <td>
                                <div class="small fw-bold text-uppercase">@item.RelatedEntity</div>
                            </td>
                            <td>
                                <small class="text-muted fst-italic">@item.Description</small>
                            </td>
                            <td class="text-end pe-4">
                                <span class="fw-bold text-danger">-@item.Amount.ToString("N2")</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-check-circle-fill text-success opacity-25 display-4 d-block mb-3"></i>
                            <p class="text-muted">Zero bank charges found for this period.</p>
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.Details.Any())
            {
                <tfoot class="bg-light">
                    <tr class="fw-bold border-top border-2">
                        <td colspan="4" class="text-end ps-4 py-3">AGGREGATE CHARGE AMOUNT</td>
                        <td class="text-end pe-4 py-3 text-danger fs-5">KES @Model.TotalCharges.ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <script>
        function exportChargesToExcel() {
            var table = document.getElementById("bankChargesTable");

            // Create worksheet from HTML table
            var wb = XLSX.utils.table_to_book(table, {
                sheet: "Bank Recon",
                raw: true // Keeps formatting clean
            });

            var filename = "Bank_Charges_Audit_" + new Date().toISOString().slice(0, 10) + ".xlsx";
            XLSX.writeFile(wb, filename);
        }
    </script>
}