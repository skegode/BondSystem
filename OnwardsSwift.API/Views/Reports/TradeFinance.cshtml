@model OnwardsSwift.Core.DTOs.TradeFinanceReportViewModel
@{
    ViewData["Title"] = "Trade Finance Report";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1 text-navy">Trade Finance Report</h1>
        <p class="text-muted mb-0">Comprehensive bond-application analysis for client pricing, bank costs, tax impact, and net profitability.</p>
    </div>
    <div>
        <img src="@Url.Content("~/images/onwards-logo.jpg")" alt="Onwards Swift" style="height:84px; width:auto; object-fit:contain; margin-left:12px;" />
    </div>
    <div class="d-flex gap-2 align-items-center">
        <button onclick="exportToPdf()" class="btn btn-outline-danger btn-sm px-3 fw-bold">
            <i class="bi bi-file-earmark-pdf me-1"></i> Export PDF
        </button>
        <a href="@Url.Action("TradeFinanceExcel", "Reports", new { from = Model.FromDate.ToString("yyyy-MM-dd"), to = Model.ToDate.ToString("yyyy-MM-dd") })" class="btn btn-outline-success btn-sm px-3 fw-bold">
            <i class="bi bi-file-earmark-excel me-1"></i> Export Excel
        </a>
        <form method="get" class="d-flex gap-2 bg-white p-2 rounded-3 shadow-sm border">
            <input type="date" name="from" value="@Model.FromDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm border-0" />
            <span class="align-self-center text-muted">to</span>
            <input type="date" name="to" value="@Model.ToDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm border-0" />
            <button type="submit" class="btn btn-navy btn-sm px-3">
                <i class="bi bi-filter"></i>
            </button>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <small class="text-muted text-uppercase fw-bold">Applications</small>
                <h3 class="fw-bold text-navy mb-0">@Model.TotalApplications</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <small class="text-muted text-uppercase fw-bold">Total Bond Amount</small>
                <h3 class="fw-bold text-navy mb-0">KES @Model.TotalBondAmount.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <small class="text-muted text-uppercase fw-bold">Total Net Profit</small>
                <h3 class="fw-bold text-success mb-0">KES @Model.TotalNetProfit.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <small class="text-muted text-uppercase fw-bold">Total Tax Calculation</small>
                <h3 class="fw-bold text-navy mb-0">KES @Model.TotalTaxCalculation.ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 py-3">
        <h6 class="mb-0 fw-bold text-navy">Requested Totals</h6>
    </div>
    <div class="card-body py-3">
        <div class="row g-3">
            <div class="col-md-4">
                <small class="text-muted text-uppercase fw-bold">Bond Amount Total</small>
                <div class="fw-bold text-navy">KES @Model.TotalBondAmount.ToString("N2")</div>
            </div>
            <div class="col-md-4">
                <small class="text-muted text-uppercase fw-bold">Client Charges Total</small>
                <div class="fw-bold text-navy">KES @Model.TotalClientCharges.ToString("N2")</div>
            </div>
            <div class="col-md-4">
                <small class="text-muted text-uppercase fw-bold">Tax Calculation Total</small>
                <div class="fw-bold text-navy">KES @Model.TotalTaxCalculation.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold text-navy">Trade Finance Detail Lines</h6>
        <span class="badge bg-light text-dark border">From @Model.FromDate.ToString("dd MMM yyyy") to @Model.ToDate.ToString("dd MMM yyyy")</span>
    </div>
    <div class="table-responsive">
        <table id="tradeFinanceTable" class="table table-hover align-middle mb-0">
            <thead class="bg-light text-uppercase small text-muted">
                <tr>
                    <th class="ps-4">Processing Date</th>
                    <th>Client</th>
                    <th class="text-end">Bond Amount</th>
                    <th class="text-end">Tenor Days</th>
                    <th>Issuing Bank</th>
                    <th class="text-end">Client Charges</th>
                    <th class="text-end">Bank Charges</th>
                    <th class="text-end">Tax Calculation</th>
                    <th class="text-end pe-4">Net Profit</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Details)
                {
                    <tr>
                        <td class="ps-4">@row.ApplicationDate.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@row.ClientName</td>
                        <td class="text-end">KES @row.BondAmount.ToString("N2")</td>
                        <td class="text-end">@row.TenorDays</td>
                        <td>@row.IssuingBank</td>
                        <td class="text-end">KES @row.ClientCharges.ToString("N2")</td>
                        <td class="text-end">KES @row.BankCharges.ToString("N2")</td>
                        <td class="text-end">KES @row.TaxCalculation.ToString("N2")</td>
                        <td class="text-end pe-4 fw-bold @(row.NetProfit >= 0 ? "text-success" : "text-danger")">
                            KES @row.NetProfit.ToString("N2")
                        </td>
                    </tr>
                }
                @if (!Model.Details.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">No bond applications found for the selected date range.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <script>
        async function exportToPdf() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });

            const logoSrc = '@Url.Content("~/images/onwards-logo.jpg")';
            // load logo into canvas to get data URL
            const loadImageDataUrl = (src) => new Promise((resolve) => {
                const img = new Image();
                img.crossOrigin = 'anonymous';
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    const maxW = 120;
                    const scale = Math.min(1, maxW / img.width);
                    canvas.width = img.width * scale;
                    canvas.height = img.height * scale;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    resolve(canvas.toDataURL('image/jpeg'));
                };
                img.onerror = () => resolve(null);
                img.src = src;
            });

            const fromDate = '@Model.FromDate.ToString("dd MMM yyyy")';
            const toDate = '@Model.ToDate.ToString("dd MMM yyyy")';

            const imgData = await loadImageDataUrl(logoSrc);

            // Header (logo will be drawn on every page in didDrawPage)
            doc.setFontSize(14);
            doc.setTextColor(0, 45, 114); // Navy
            doc.text('Trade Finance Report', 40, 60);
            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text(`Period: ${fromDate} to ${toDate}`, 40, 76);

            // Summary row
            doc.setFontSize(9);
            doc.setTextColor(50);
            doc.text(`Applications: @Model.TotalApplications   |   Bond Amount: KES @Model.TotalBondAmount.ToString("N2")   |   Client Charges: KES @Model.TotalClientCharges.ToString("N2")   |   Tax: KES @Model.TotalTaxCalculation.ToString("N2")   |   Net Profit: KES @Model.TotalNetProfit.ToString("N2")`, 40, 92);

            // Table
            const table = document.getElementById('tradeFinanceTable');
            const headers = [];
            table.querySelectorAll('thead th').forEach(th => headers.push(th.innerText.trim()));

            const rows = [];
            table.querySelectorAll('tbody tr').forEach(tr => {
                const cells = [];
                tr.querySelectorAll('td').forEach(td => cells.push(td.innerText.trim()));
                if (cells.length > 1) rows.push(cells);
            });

            doc.autoTable({
                head: [headers],
                body: rows,
                startY: 104,
                styles: { fontSize: 8, cellPadding: 4 },
                headStyles: { fillColor: [0, 45, 114], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [245, 247, 250] },
                columnStyles: {
                    2: { halign: 'right' },
                    3: { halign: 'right' },
                    5: { halign: 'right' },
                    6: { halign: 'right' },
                    7: { halign: 'right' },
                    8: { halign: 'right' }
                },
                didDrawPage: (data) => {
                    const pageCount = doc.internal.getNumberOfPages();
                    const pageWidth = doc.internal.pageSize.getWidth();
                    // Draw logo at top-right only on the first page
                    if (imgData && data.pageNumber === 1) {
                        const imgW = 100;
                        const imgH = 40;
                        doc.addImage(imgData, 'JPEG', pageWidth - 40 - imgW, 20, imgW, imgH);
                    }

                    doc.setFontSize(8);
                    doc.setTextColor(150);
                    doc.text(`Page ${data.pageNumber} of ${pageCount}`, pageWidth - 80, doc.internal.pageSize.getHeight() - 20);
                }
            });

            doc.save(`TradeFinance_${fromDate.replace(/ /g,'_')}_to_${toDate.replace(/ /g,'_')}.pdf`);
        }
    </script>
}
