@model OnwardsSwift.Core.DTOs.RevenueReportViewModel
@{
    ViewData["Title"] = "Revenue Report";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4 animate__animated animate__fadeIn">
    <div>
        <h1 class="h3 fw-bold mb-1 text-navy">Revenue Analysis</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb extra-small text-uppercase mb-0">
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Intelligence</a></li>
                <li class="breadcrumb-item active">Revenue Streams</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <button onclick="exportToExcel()" class="btn btn-outline-success btn-sm px-3 fw-bold">
            <i class="bi bi-file-earmark-excel me-1"></i> Export to Excel
        </button>

        <form method="get" class="d-flex gap-2 bg-white p-2 rounded-3 shadow-sm border">
            <input type="date" name="from" value="@(((DateTime)ViewBag.From).ToString("yyyy-MM-dd"))" class="form-control form-control-sm border-0">
            <span class="align-self-center text-muted">to</span>
            <input type="date" name="to" value="@(((DateTime)ViewBag.To).ToString("yyyy-MM-dd"))" class="form-control form-control-sm border-0">
            <button type="submit" class="btn btn-navy btn-sm px-3">
                <i class="bi bi-filter"></i>
            </button>
        </form>
    </div>
</div>

<div class="row g-3 mb-4 animate__animated animate__fadeInUp">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4 bg-navy text-white h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #002D72 0%, #001d4a 100%);">
            <div class="position-relative z-1">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-white text-navy me-2">LIVE</span>
                    <small class="text-uppercase opacity-75 fw-bold letter-spacing-1">Total Revenue Performance</small>
                </div>
                <h1 class="display-4 fw-bold mb-0">KES @Model.TotalRevenue.ToString("N2")</h1>
                <div class="mt-3 d-flex align-items-center">
                    <div class="me-4">
                        <small class="d-block opacity-75">Volume</small>
                        <span class="fw-bold">@Model.Details.Count Transactions</span>
                    </div>
                    <div>
                        <small class="d-block opacity-75">Avg Yield</small>
                        <span class="fw-bold">KES @(Model.Details.Any() ? (Model.TotalRevenue / Model.Details.Count).ToString("N0") : "0")</span>
                    </div>
                </div>
            </div>
            <i class="bi bi-graph-up-arrow position-absolute end-0 bottom-0 text-white opacity-10 m-n3" style="font-size: 10rem;"></i>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 overflow-hidden">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold small text-uppercase text-muted mb-0">Period Summary</h6>
            </div>
            <div class="card-body pt-0">
                <div class="p-3 rounded-3 bg-light mb-3">
                    <small class="text-muted d-block">Start Date</small>
                    <span class="fw-bold text-navy">@(((DateTime)ViewBag.From).ToString("dd MMMM, yyyy"))</span>
                </div>
                <div class="p-3 rounded-3 bg-light">
                    <small class="text-muted d-block">End Date</small>
                    <span class="fw-bold text-navy">@(((DateTime)ViewBag.To).ToString("dd MMMM, yyyy"))</span>
                </div>
            </div>
            <div class="card-footer bg-navy-subtle border-0 text-center py-2">
                <small class="text-navy fw-bold">Operational Status: Optimal</small>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm animate__animated animate__fadeInUp">
    <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold text-navy"><i class="bi bi-list-ul me-2"></i>Audit Trail: Detailed Transactions</h6>
    </div>
    <div class="table-responsive">
        <table id="revenueTable" class="table table-hover align-middle mb-0">
            <thead class="bg-light extra-small text-uppercase text-muted">
                <tr>
                    <th class="ps-4">Date & Time</th>
                    <th>Reference</th>
                    <th>Beneficiary / Client</th>
                    <th>Narrative</th>
                    <th class="text-end pe-4">Revenue (KES)</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (Model.Details.Any())
                {
                    foreach (var item in Model.Details)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-navy">@item.Date.ToString("dd-MMM-yyyy")</div>
                                <div class="extra-small text-muted">@item.Date.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="badge bg-light text-dark border mb-1">Inv: @item.Reference</span>
                                    <small class="text-muted font-monospace">Bond: @item.BondNumber</small>
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark text-uppercase small">@item.ClientName</div>
                                <div class="extra-small text-primary"><i class="bi bi-patch-check-fill me-1"></i>Verified Transaction</div>
                            </td>
                            <td class="small text-muted" style="max-width: 250px;">
                                @item.Description
                            </td>
                            <td class="text-end pe-4">
                                <span class="fw-bold fs-6 text-dark">@item.Amount.ToString("N2")</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="80" class="opacity-25 mb-3">
                            <p class="text-muted">No revenue data available for the selected parameters.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <script>
        function exportToExcel() {
            // 1. Get the table element
            var table = document.getElementById("revenueTable");

            // 2. Convert table to worksheet
            var wb = XLSX.utils.table_to_book(table, { sheet: "Revenue Report" });

            // 3. Generate filename with current date
            var filename = "Revenue_Report_" + new Date().toISOString().slice(0, 10) + ".xlsx";

            // 4. Trigger download
            XLSX.writeFile(wb, filename);
        }
    </script>
}